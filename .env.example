# =============================================================
# AssistenciaPlus - Fitxer d'exemple de configuració
# Copia aquest fitxer a .env i omple els valors
# =============================================================

APP_NAME=AssistenciaPlus
APP_ENV=production
APP_PUBLIC_URL=https://tuteapps.ddns.net:4446
APP_USE_HTTPS=true

# PORT IMPORTANT:
#   Al servidor local: APP_PORT=443  (el nginx escolta al port 443 del host)
#   El router fa NAT: extern 4446 → servidor 443
#   APP_PORT=4446 NO és correcte per al servidor; 4446 és el port del router.
APP_PORT=443

DB_HOST=db
DB_PORT=5432
DB_NAME=assistenciaplus
DB_USER=appuser
DB_PASSWORD=CHANGE_ME

CONNECTION_STRING=Host=db;Port=5432;Database=assistenciaplus;Username=appuser;Password=CHANGE_ME

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_CONNECTION=redis:6379,password=CHANGE_ME,ssl=false,abortConnect=false

JWT_SECRET=CHANGE_ME_min_32_chars
JWT_ISSUER=AssistenciaPlus
JWT_AUDIENCE=AssistenciaPlus
JWT_EXPIRY_MINUTES=480

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=compte@gmail.com
SMTP_PASSWORD=app_password
SMTP_FROM_NAME=AssistenciaPlus
SMTP_FROM_EMAIL=compte@gmail.com

OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
SSL_KEY_PATH=/etc/nginx/certs/privkey.pem

LOG_LEVEL=Information
LOG_PATH=/app/logs

# Escola
ESCOLA_EMAIL_INFORMES=a8059721@xtec.cat

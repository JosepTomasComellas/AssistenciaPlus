@page "/informes"
@attribute [Authorize(Roles = "EquipDirectiu,Administratiu")]
@inject GrupService GrupService
@inject InformesService InformesService
@inject ConfiguracioService ConfiguracioService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject BreadcrumbService BreadcrumbService

<PageTitle>Informes — AssistenciaPlus</PageTitle>

<div class="mb-5">
    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">Informes d'assistència</MudText>
    <MudText Typo="Typo.subtitle1" Style="color:#4A5568">
        Consulta i exporta les dades d'assistència
    </MudText>
</div>

<!-- Filtres -->
<MudPaper Elevation="1" Class="pa-5 mb-5" Style="border-radius:12px">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="string" @bind-Value="_tipusInforme"
                Label="Tipus d'informe"
                Variant="Variant.Outlined">
                <MudSelectItem Value="@("mensual")">Informe mensual</MudSelectItem>
                <MudSelectItem Value="@("trimestral")">Informe trimestral</MudSelectItem>
            </MudSelect>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="Guid?" @bind-Value="_grupSeleccionat"
                Label="Grup"
                Variant="Variant.Outlined"
                Disabled="_carregantGrups">
                <MudSelectItem Value="@((Guid?)null)">Tots els grups</MudSelectItem>
                @foreach (var grup in _grups)
                {
                    <MudSelectItem Value="@((Guid?)grup.Id)">
                        @grup.NomComplet (@grup.CursCodi)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        @if (_tipusInforme == "mensual")
        {
            <MudItem xs="6" sm="4" md="2">
                <MudSelect T="int" @bind-Value="_any"
                    Label="Any"
                    Variant="Variant.Outlined">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                    {
                        var year = y;
                        <MudSelectItem Value="@year">@year</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="6" sm="4" md="2">
                <MudSelect T="int" @bind-Value="_mes"
                    Label="Mes"
                    Variant="Variant.Outlined">
                    @foreach (var (num, nom) in _mesos)
                    {
                        <MudSelectItem Value="@num">@nom</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        }
        else
        {
            <MudItem xs="6" sm="4" md="2">
                <MudSelect T="int" @bind-Value="_trimestre"
                    Label="Trimestre"
                    Variant="Variant.Outlined">
                    <MudSelectItem Value="1">1r trimestre</MudSelectItem>
                    <MudSelectItem Value="2">2n trimestre</MudSelectItem>
                    <MudSelectItem Value="3">3r trimestre</MudSelectItem>
                </MudSelect>
            </MudItem>
        }

        <MudItem xs="12" sm="4" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                StartIcon="@Icons.Material.Filled.BarChart"
                FullWidth="true"
                OnClick="GenerarInformeAsync"
                Disabled="_generant || !_grupSeleccionat.HasValue">
                @if (_generant)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Generar informe
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Resultats -->
@{
    var alumnesInforme = _tipusInforme == "mensual"
        ? _informe?.Alumnes
        : _informeTrimestral?.Alumnes;
    var titolInforme = _tipusInforme == "mensual" ? _informe?.Titol : _informeTrimestral?.Titol;
    var anyAcademicInforme = _tipusInforme == "mensual"
        ? _informe?.AnyAcademic : _informeTrimestral?.AnyAcademic;
    var totalAlumnesInforme = _tipusInforme == "mensual"
        ? _informe?.TotalAlumnes : _informeTrimestral?.TotalAlumnes;
    var hiHaResultats = alumnesInforme != null;
}

@if (hiHaResultats && alumnesInforme != null)
{
    <MudPaper Elevation="1" Class="pa-5" Style="border-radius:12px">

        <!-- Capçalera de l'informe -->
        <div class="d-flex align-center justify-space-between flex-wrap gap-3 mb-5">
            <div>
                <MudText Typo="Typo.h5" Style="font-weight:700">
                    @titolInforme
                </MudText>
                <MudText Typo="Typo.body2" Style="color:#718096">
                    @anyAcademicInforme ·
                    @if (_tipusInforme == "mensual")
                    {
                        <span>@_mesos.FirstOrDefault(m => m.Num == _mes).Nom @_any</span>
                    }
                    else
                    {
                        <span>@(_trimestre)r trimestre (@_informeTrimestral?.DataInici.ToString("dd/MM") – @_informeTrimestral?.DataFi.ToString("dd/MM/yyyy"))</span>
                    }
                    · @totalAlumnesInforme alumnes
                </MudText>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <MudButton Variant="Variant.Outlined" Color="Color.Success"
                    StartIcon="@Icons.Material.Filled.TableView"
                    OnClick="ExportarExcelAsync"
                    Disabled="_exportant">
                    @if (_exportant)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Exportar Excel
                </MudButton>
                <AuthorizeView Roles="EquipDirectiu">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                        StartIcon="@Icons.Material.Filled.Email"
                        OnClick="EnviarInformeAsync"
                        Disabled="@(_enviant || (_tipusInforme == "mensual" && _informe == null) || (_tipusInforme == "trimestral" && _informeTrimestral == null))">
                        @if (_enviant)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Enviar per correu
                    </MudButton>
                </AuthorizeView>
            </div>
        </div>

        <!-- Estadístiques globals -->
        <MudGrid Class="mb-5">
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="0"
                    Style="background:#F0FFF4;border-radius:8px">
                    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">
                        @alumnesInforme.Count(a => !a.EsAlerta)
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#718096">Sense alertes</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="0"
                    Style="background:#FFFBF0;border-radius:8px">
                    <MudText Typo="Typo.h4" Style="font-weight:700;color:#F57F17">
                        @alumnesInforme.Count(a => a.EsAlerta && !a.EsCritic)
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#718096">En alerta (&gt;10%)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="0"
                    Style="background:#FFF5F5;border-radius:8px">
                    <MudText Typo="Typo.h4" Style="font-weight:700;color:#C62828">
                        @alumnesInforme.Count(a => a.EsCritic)
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#718096">Situació crítica (&gt;25%)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="0"
                    Style="background:#E8F5E9;border-radius:8px">
                    @{
                        var mitjana = alumnesInforme.Any()
                            ? alumnesInforme.Average(a => (double)a.PercentatgeAbsencia)
                            : 0;
                    }
                    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">
                        @($"{mitjana:F1}")%
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#718096">% absència mitjana</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Taula d'alumnes -->
        <MudTable Items="alumnesInforme.OrderByDescending(a => a.PercentatgeAbsencia)"
            Hover="true" Dense="true" Striped="true"
            Style="border-radius:8px;overflow:hidden">
            <HeaderContent>
                <MudTh>Alumne</MudTh>
                <MudTh Style="text-align:center">Presents</MudTh>
                <MudTh Style="text-align:center">Absents</MudTh>
                <MudTh Style="text-align:center">% Absència</MudTh>
                <MudTh Style="text-align:center">Estat</MudTh>
                <MudTh Style="text-align:center">PDF</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Style="font-weight:500">@context.AlumneNom</MudText>
                    <MudText Typo="Typo.caption" Style="color:#718096">@context.GrupNom</MudText>
                </MudTd>
                <MudTd Style="text-align:center">@context.FrangesPresents</MudTd>
                <MudTd Style="text-align:center">@context.FrangesAbsents</MudTd>
                <MudTd Style="text-align:center">
                    <MudText Style="@GetPercentatgeStyle(context)">
                        @($"{context.PercentatgeAbsencia:F1}")%
                    </MudText>
                </MudTd>
                <MudTd Style="text-align:center">
                    @if (context.EsCritic)
                    {
                        <MudChip T="string" Color="Color.Error" Size="Size.Small"
                            Icon="@Icons.Material.Filled.Warning">
                            Crític
                        </MudChip>
                    }
                    else if (context.EsAlerta)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                            Icon="@Icons.Material.Filled.Info">
                            Alerta
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small"
                            Icon="@Icons.Material.Filled.CheckCircle">
                            Correcte
                        </MudChip>
                    }
                </MudTd>
                <MudTd Style="text-align:center">
                    <MudTooltip Text="Descarregar informe PDF d'aquest alumne">
                        <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf"
                            Size="Size.Small"
                            Color="Color.Error"
                            Disabled="@_descarregantPdf.Contains(context.AlumneId)"
                            OnClick="@(() => DescarregarPdfAlumneAsync(context.AlumneId))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}
else if (_errorInforme != null)
{
    <MudAlert Severity="Severity.Error">@_errorInforme</MudAlert>
}

@code {
    private string _tipusInforme = "mensual";
    private List<GrupModel> _grups = [];
    private Guid? _grupSeleccionat;
    private Guid _anyAcademicId;
    private int _any = DateTime.Now.Year;
    private int _mes = DateTime.Now.Month;
    private int _trimestre = (DateTime.Now.Month - 1) / 3 + 1;
    private bool _carregantGrups = true;
    private bool _generant;
    private bool _enviant;
    private bool _exportant;
    private readonly HashSet<Guid> _descarregantPdf = [];
    private InformeMensualModel? _informe;
    private InformeTrimestralModel? _informeTrimestral;
    private string? _errorInforme;

    private readonly (int Num, string Nom)[] _mesos =
    [
        (1, "Gener"), (2, "Febrer"), (3, "Març"), (4, "Abril"),
        (5, "Maig"), (6, "Juny"), (7, "Juliol"), (8, "Agost"),
        (9, "Setembre"), (10, "Octubre"), (11, "Novembre"), (12, "Desembre")
    ];

    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Set(
            new("Inici", "/"),
            new("Informes", null, true));
        _grups = await GrupService.GetGrupsAsync();
        if (_grups.Count == 1)
            _grupSeleccionat = _grups[0].Id;

        var anys = await ConfiguracioService.GetAnysAcademicsAsync();
        var anyActiu = anys.FirstOrDefault(a => a.EsActiu);
        if (anyActiu != null)
            _anyAcademicId = anyActiu.Id;

        _carregantGrups = false;
    }

    private async Task GenerarInformeAsync()
    {
        if (!_grupSeleccionat.HasValue) return;

        _generant = true;
        _errorInforme = null;
        _informe = null;
        _informeTrimestral = null;

        try
        {
            if (_tipusInforme == "mensual")
            {
                _informe = await InformesService.GetInformeMensualGrupAsync(
                    _grupSeleccionat.Value, _any, _mes);
                if (_informe == null)
                    _errorInforme = "No s'ha pogut generar l'informe. Comproveu els filtres.";
            }
            else
            {
                if (_anyAcademicId == Guid.Empty)
                {
                    _errorInforme = "No hi ha cap any acadèmic actiu.";
                }
                else
                {
                    _informeTrimestral = await InformesService.GetInformeTrimestralGrupAsync(
                        _grupSeleccionat.Value, _trimestre, _anyAcademicId);
                    if (_informeTrimestral == null)
                        _errorInforme = "No s'ha pogut generar l'informe trimestral.";
                }
            }
        }
        catch (Exception ex)
        {
            _errorInforme = $"Error: {ex.Message}";
        }

        _generant = false;
    }

    private async Task ExportarExcelAsync()
    {
        if (!_grupSeleccionat.HasValue) return;
        if (_tipusInforme == "mensual" && _informe == null) return;
        if (_tipusInforme == "trimestral" && _informeTrimestral == null) return;

        _exportant = true;
        try
        {
            byte[]? data; string? nom; string? error;

            if (_tipusInforme == "mensual")
                (data, nom, error) = await InformesService.ExportarExcelMensualAsync(
                    _grupSeleccionat.Value, _any, _mes);
            else
                (data, nom, error) = await InformesService.ExportarExcelTrimestralAsync(
                    _grupSeleccionat.Value, _trimestre, _anyAcademicId);

            if (data != null)
                await JS.InvokeVoidAsync("downloadFile", nom,
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", data);
            else
                Snackbar.Add(error ?? "Error en l'exportació", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Error en descarregar l'Excel", Severity.Error);
        }
        _exportant = false;
    }

    private async Task EnviarInformeAsync()
    {
        if (!_grupSeleccionat.HasValue) return;

        _enviant = true;
        bool ok = false; string? error = null;

        if (_tipusInforme == "mensual")
        {
            if (_informe == null) { _enviant = false; return; }
            (ok, error) = await InformesService.EnviarInformeMensualAsync(
                _grupSeleccionat.Value, _any, _mes);
        }
        else
        {
            if (_informeTrimestral == null || _anyAcademicId == Guid.Empty) { _enviant = false; return; }
            (ok, error) = await InformesService.EnviarInformeTrimestralAsync(
                _grupSeleccionat.Value, _trimestre, _anyAcademicId);
        }

        if (ok)
            Snackbar.Add("Informe enviat per correu correctament", Severity.Success);
        else
            Snackbar.Add(error ?? "Error al enviar l'informe", Severity.Error);

        _enviant = false;
    }

    private async Task DescarregarPdfAlumneAsync(Guid alumneId)
    {
        if (!_grupSeleccionat.HasValue) return;
        _descarregantPdf.Add(alumneId);
        try
        {
            byte[]? data; string? nom; string? error;
            if (_tipusInforme == "mensual")
                (data, nom, error) = await InformesService.ExportarPdfAlumneAsync(
                    alumneId, _grupSeleccionat.Value, "mensual", any: _any, mes: _mes);
            else
                (data, nom, error) = await InformesService.ExportarPdfAlumneAsync(
                    alumneId, _grupSeleccionat.Value, "trimestral",
                    trimestre: _trimestre, anyAcademicId: _anyAcademicId);

            if (data != null)
                await JS.InvokeVoidAsync("downloadFile", nom, "application/pdf", data);
            else
                Snackbar.Add(error ?? "Error en generar el PDF", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Error en descarregar el PDF", Severity.Error);
        }
        _descarregantPdf.Remove(alumneId);
    }

    private static string GetPercentatgeStyle(InformeAlumneModel a)
    {
        if (a.EsCritic) return "font-weight:700;color:#C62828";
        if (a.EsAlerta) return "font-weight:600;color:#F57F17";
        return "color:#2E7D32";
    }
}

@page "/perfil"
@attribute [Authorize]
@inject AuthService AuthService
@inject ISnackbar Snackbar
@inject BreadcrumbService BreadcrumbService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>El meu perfil — AssistenciaPlus</PageTitle>

<div class="mb-5">
    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">El meu perfil</MudText>
</div>

@if (_usuari == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="5">
            <MudPaper Elevation="1" Class="pa-6" Style="border-radius:12px">
                <div class="d-flex flex-column align-center mb-5">
                    @if (!string.IsNullOrEmpty(_usuari.FotoPath))
                    {
                        <img src="@_usuari.FotoPath" alt=""
                            style="width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:12px;border:3px solid #E2E8F0" />
                    }
                    else
                    {
                        <MudAvatar Color="Color.Primary" Size="Size.Large"
                            Style="width:80px;height:80px;font-size:1.8rem;font-weight:700;margin-bottom:12px">
                            @_usuari.NomComplet[..Math.Min(2, _usuari.NomComplet.Length)]
                        </MudAvatar>
                    }
                    <MudText Typo="Typo.h5" Style="font-weight:700">
                        @_usuari.NomComplet
                    </MudText>
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="mt-1">
                        @GetRolText(_usuari.Rol)
                    </MudChip>
                    <div class="mt-3 d-flex flex-column align-center">
                        @if (!_pujantFoto)
                        {
                            <InputFile id="inputFotoPerfil" OnChange="PujarFotoAsync"
                                accept="image/jpeg,image/png,image/webp"
                                style="display:none" />
                        }
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                            StartIcon="@Icons.Material.Filled.PhotoCamera"
                            HtmlTag="label" for="inputFotoPerfil"
                            Disabled="_pujantFoto">
                            @if (_pujantFoto)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                            }
                            Canviar foto
                        </MudButton>
                        <MudText Typo="Typo.caption" Style="color:#A0AEC0;margin-top:4px">
                            JPEG, PNG o WebP · màx. 2 MB
                        </MudText>
                    </div>
                </div>

                <MudDivider Class="mb-4" />

                <MudStack Spacing="3">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:#A0AEC0;text-transform:uppercase;letter-spacing:0.05em">
                            Correu electrònic
                        </MudText>
                        <MudText Style="font-weight:500">@_usuari.Email</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Style="color:#A0AEC0;text-transform:uppercase;letter-spacing:0.05em">
                            Idioma preferit
                        </MudText>
                        <MudText Style="font-weight:500">
                            @(_usuari.Idioma == "ca" ? "Català" : "Castellà")
                        </MudText>
                    </div>
                    @if (_usuari.UltimAcces.HasValue)
                    {
                        <div>
                            <MudText Typo="Typo.caption" Style="color:#A0AEC0;text-transform:uppercase;letter-spacing:0.05em">
                                Últim accés
                            </MudText>
                            <MudText Style="font-weight:500">
                                @_usuari.UltimAcces.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </div>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Elevation="1" Class="pa-6" Style="border-radius:12px">
                <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600">
                    Canviar contrasenya
                </MudText>

                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_contrasenyaActual"
                        Label="Contrasenya actual"
                        InputType="InputType.Password"
                        Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_contrasenyaNova"
                        Label="Nova contrasenya"
                        InputType="InputType.Password"
                        Variant="Variant.Outlined"
                        HelperText="Mínim 12 caràcters" />
                    <MudTextField @bind-Value="_contrasenyaConfirm"
                        Label="Confirmar nova contrasenya"
                        InputType="InputType.Password"
                        Variant="Variant.Outlined" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                        OnClick="CanviarContrasenyaAsync"
                        Disabled="_canviant"
                        StartIcon="@Icons.Material.Filled.Lock">
                        @if (_canviant)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Canviar contrasenya
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private UsuariModel? _usuari;
    private string _contrasenyaActual = string.Empty;
    private string _contrasenyaNova = string.Empty;
    private string _contrasenyaConfirm = string.Empty;
    private bool _canviant;
    private bool _pujantFoto;

    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Set(
            new("Inici", "/"),
            new("El meu perfil", null, true));
        _usuari = await AuthService.GetCurrentUserFromApiAsync();
    }

    private async Task PujarFotoAsync(InputFileChangeEventArgs e)
    {
        _pujantFoto = true;
        try
        {
            var (ok, fotoPath, error) = await AuthService.PujarFotoPerfilAsync(e.File);
            if (ok && fotoPath != null)
            {
                _usuari = _usuari! with { FotoPath = fotoPath };
                await AuthService.GetCurrentUserFromApiAsync(); // Actualitza localStorage
                Snackbar.Add("Foto actualitzada correctament", Severity.Success);
            }
            else
            {
                Snackbar.Add(error ?? "Error al pujar la foto", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("No s'ha pogut pujar la foto. Comprova la connexió.", Severity.Error);
        }
        finally
        {
            _pujantFoto = false;
        }
    }

    private async Task CanviarContrasenyaAsync()
    {
        if (string.IsNullOrWhiteSpace(_contrasenyaActual) ||
            string.IsNullOrWhiteSpace(_contrasenyaNova))
        {
            Snackbar.Add("Omple tots els camps", Severity.Warning);
            return;
        }

        if (_contrasenyaNova != _contrasenyaConfirm)
        {
            Snackbar.Add("Les contrasenyes noves no coincideixen", Severity.Warning);
            return;
        }

        if (_contrasenyaNova.Length < 12)
        {
            Snackbar.Add("La contrasenya ha de tenir mínim 12 caràcters", Severity.Warning);
            return;
        }

        _canviant = true;
        var ok = await AuthService.CanviarContrasenyaAsync(_contrasenyaActual, _contrasenyaNova);

        if (ok)
        {
            Snackbar.Add("Contrasenya canviada correctament", Severity.Success);
            _contrasenyaActual = string.Empty;
            _contrasenyaNova = string.Empty;
            _contrasenyaConfirm = string.Empty;
        }
        else
        {
            Snackbar.Add("La contrasenya actual és incorrecta", Severity.Error);
        }

        _canviant = false;
    }

    private static string GetRolText(string rol) => rol switch
    {
        "EquipDirectiu" => "Equip Directiu",
        "Administratiu" => "Administratiu/va",
        _ => "Mestre/a"
    };
}

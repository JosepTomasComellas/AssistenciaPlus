@page "/configuracio/alumnes"
@attribute [Authorize(Roles = "EquipDirectiu")]
@inject GrupService GrupService
@inject AlumnesService AlumnesService
@inject ConfiguracioService ConfiguracioService
@inject ISnackbar Snackbar
@inject BreadcrumbService BreadcrumbService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Alumnes i grups — Configuració</PageTitle>

<div class="mb-5">
    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">Alumnes i grups</MudText>
    <MudText Typo="Typo.subtitle1" Style="color:#4A5568">
        Gestió dels alumnes del centre
    </MudText>
</div>

<!-- Gestió de grups -->
<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px">
    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600">Grups actuals</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
            StartIcon="@Icons.Material.Filled.CreateNewFolder"
            OnClick="ObrirCrearGrup">
            Nou grup
        </MudButton>
    </div>

    @if (_grups.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            No hi ha cap grup. Crea el primer grup per poder afegir alumnes.
        </MudAlert>
    }
    else
    {
        <MudChipSet T="Guid?" SelectionMode="SelectionMode.SingleSelection"
            SelectedValue="_grupSeleccionat"
            SelectedValueChanged="GrupCanviatAsync"
            Class="flex-wrap gap-2">
            @foreach (var g in _grups.OrderBy(g => g.CicleNom).ThenBy(g => g.CursNom).ThenBy(g => g.Lletra))
            {
                <MudChip T="Guid?" Value="@((Guid?)g.Id)"
                    Color="@(_grupSeleccionat == g.Id ? Color.Primary : Color.Default)"
                    Variant="@(_grupSeleccionat == g.Id ? Variant.Filled : Variant.Outlined)"
                    Icon="@Icons.Material.Filled.Group">
                    <div>
                        <span>@g.NomComplet</span>
                        <MudText Typo="Typo.caption" Class="ml-1" Style="opacity:0.75">
                            (@g.NombreAlumnes al.)
                        </MudText>
                        @if (!string.IsNullOrEmpty(g.TutorNomComplet))
                        {
                            <MudText Typo="Typo.caption" Style="display:block;opacity:0.8">
                                @g.TutorNomComplet
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="display:block;color:#E57373">
                                Sense tutor assignat
                            </MudText>
                        }
                    </div>
                </MudChip>
            }
        </MudChipSet>
    }
</MudPaper>

<!-- Accions del grup seleccionat -->
@if (_grupSeleccionat.HasValue)
{
    var grupActual = _grups.FirstOrDefault(g => g.Id == _grupSeleccionat);
    <MudPaper Elevation="0" Class="pa-3 mb-3"
        Style="border:1px solid #E2E8F0;border-radius:10px;background:#F7FAFC">
        <div class="d-flex align-center gap-3 flex-wrap">
            <MudText Typo="Typo.subtitle2" Style="font-weight:600">
                Grup: @grupActual?.NomComplet (@grupActual?.CicleNom)
            </MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                StartIcon="@Icons.Material.Filled.PersonAdd"
                OnClick="ObrirCrearAlumne">
                Afegir alumne
            </MudButton>
            <MudTooltip Text="Importar alumnes des d'Excel (Esfera/Alexia)">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                    StartIcon="@Icons.Material.Filled.TableChart"
                    OnClick="ObrirImportarExcel">
                    Importar Excel
                </MudButton>
            </MudTooltip>
            <MudTooltip Text="Gestionar mestres autoritzats a passar llista en aquest grup">
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                    StartIcon="@Icons.Material.Filled.SupervisorAccount"
                    OnClick="() => ObrirMestresGrup(grupActual!)">
                    Mestres
                </MudButton>
            </MudTooltip>
            <MudTooltip Text="Editar grup (canviar tutor)">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                    Color="Color.Default" Size="Size.Small"
                    OnClick="() => ObrirEditarGrup(grupActual!)" />
            </MudTooltip>
            @if (grupActual?.NombreAlumnes == 0)
            {
                <MudTooltip Text="Esborrar grup buit">
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                        Color="Color.Error" Size="Size.Small"
                        OnClick="() => EsborrarGrupAsync(grupActual!.Id)" />
                </MudTooltip>
            }
        </div>
    </MudPaper>
}

@if (_grupSeleccionat.HasValue)
{
    @if (_carregantAlumnes)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden">
            <MudTable Items="_alumnes.OrderBy(a => a.Cognom1)" Hover="true" Dense="true">
                <HeaderContent>
                    <MudTh Style="width:50px">#</MudTh>
                    <MudTh>Alumne/a</MudTh>
                    <MudTh>Data de naixement</MudTh>
                    <MudTh Style="text-align:center">Actiu</MudTh>
                    <MudTh Style="text-align:center">Accions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Typo="Typo.caption" Style="color:#A0AEC0">
                            @context.OrdreFusteta
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <div class="d-flex align-center gap-2">
                            @if (!string.IsNullOrEmpty(context.FotoPath))
                            {
                                <img src="@context.FotoPath" alt=""
                                    style="width:32px;height:32px;border-radius:50%;object-fit:cover;flex-shrink:0" />
                            }
                            else
                            {
                                <MudAvatar Color="Color.Primary" Size="Size.Small"
                                    Style="font-size:0.75rem;font-weight:700">
                                    @context.Inicials
                                </MudAvatar>
                            }
                            <div>
                                <MudText Style="font-weight:500">@context.NomComplet</MudText>
                                @if (!string.IsNullOrEmpty(context.NomFusteta) &&
                                     context.NomFusteta != context.Nom)
                                {
                                    <MudText Typo="Typo.caption" Style="color:#718096">
                                        Fusteta: @context.NomFusteta
                                    </MudText>
                                }
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>
                        @(context.DataNaixement?.ToString("dd/MM/yyyy") ?? "—")
                    </MudTd>
                    <MudTd Style="text-align:center">
                        <MudIcon
                            Icon="@(context.EsActiu ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                            Color="@(context.EsActiu ? Color.Success : Color.Default)"
                            Size="Size.Small" />
                    </MudTd>
                    <MudTd Style="text-align:center">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                            Size="Size.Small" Color="Color.Primary"
                            OnClick="() => ObrirEditarAlumne(context)" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Class="pa-4" Style="color:#A0AEC0">
                        Cap alumne en aquest grup
                    </MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    }
}

<!-- Confirmació d'esborrat -->
<MudMessageBox @ref="_confirmBox" Title="Confirmar esborrat" CancelText="Cancel·lar">
    <MessageContent>@_confirmMissatge</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
            StartIcon="@Icons.Material.Filled.DeleteForever">
            Sí, esborrar
        </MudButton>
    </YesButton>
</MudMessageBox>

<!-- Dialog: Mestres autoritzats -->
<MudDialog @bind-Visible="_dialogMestresObert" Options="@_dialogOptionsSmall">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Mestres autoritzats — @_grupMestresActual?.NomComplet
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.caption" Style="color:#718096">
                A més del tutor/a principal, pots autoritzar altres mestres a passar llista en aquest grup.
            </MudText>

            @if (_mestresGrup.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Cap mestre addicional autoritzat.
                </MudAlert>
            }
            else
            {
                @foreach (var m in _mestresGrup)
                {
                    <div class="d-flex align-center justify-space-between">
                        <MudText>@m.NomComplet</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle"
                            Color="Color.Error" Size="Size.Small"
                            OnClick="() => TreureMestreGrupAsync(m.Id)" />
                    </div>
                }
            }

            <MudDivider />
            <MudText Typo="Typo.subtitle2" Style="font-weight:600">Afegir mestre</MudText>
            <MudSelect T="Guid" @bind-Value="_mestreAfegirId"
                Label="Mestre a autoritzar" Variant="Variant.Outlined" Dense="true">
                @foreach (var u in _mestresDisponibles)
                {
                    <MudSelectItem T="Guid" Value="@u.Id">@u.NomComplet</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                StartIcon="@Icons.Material.Filled.AddCircle"
                OnClick="AfegirMestreGrupAsync"
                Disabled="_desant || _mestreAfegirId == Guid.Empty">
                Autoritzar mestre
            </MudButton>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogMestresObert = false" Variant="Variant.Text">Tancar</MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog: Importar alumnes Excel -->
<MudDialog @bind-Visible="_dialogExcelObert" Options="@_dialogOptionsSmall">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Importar alumnes des d'Excel — @(_grupSeleccionat.HasValue ? _grups.FirstOrDefault(g => g.Id == _grupSeleccionat)?.NomComplet : "")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Info" Dense="true">
                El fitxer ha de ser .xlsx amb columnes: <strong>Cognom1</strong>, <strong>Nom</strong> (obligatòries)
                i opcionalment <strong>Cognom2</strong> i <strong>DataNaixement</strong>.
                Compatible amb exportació Esfera/Alexia.
            </MudAlert>
            <InputFile id="inputExcelAlumnes" OnChange="ImportarExcelAsync"
                accept=".xlsx,.xls"
                style="display:none" />
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                StartIcon="@Icons.Material.Filled.TableChart"
                HtmlTag="label" for="inputExcelAlumnes"
                Disabled="_importantExcel">
                @if (_importantExcel)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    <span>Important...</span>
                }
                else
                {
                    <span>Seleccionar fitxer Excel</span>
                }
            </MudButton>
            @if (_resultatImportacio != null)
            {
                <MudAlert Severity="Severity.Success" Dense="true">
                    Importats @_resultatImportacio.Importats alumnes correctament.
                    @if (_resultatImportacio.Ignorats > 0)
                    {
                        <span> (@_resultatImportacio.Ignorats ignorats)</span>
                    }
                </MudAlert>
                @if (_resultatImportacio.Errors.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        @foreach (var e in _resultatImportacio.Errors.Take(5))
                        {
                            <MudText Typo="Typo.caption">@e</MudText>
                        }
                    </MudAlert>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TancarDialogExcel" Variant="Variant.Text">Tancar</MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog crear/editar grup -->
<MudDialog @bind-Visible="_dialogGrupObert" Options="@_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editantGrup == null ? "Nou grup" : "Editar grup")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @if (_editantGrup == null)
            {
                <MudSelect T="Guid" @bind-Value="_formGrupCursId" Label="Curs"
                    Variant="Variant.Outlined" Required="true">
                    @foreach (var cicle in _cicles)
                    {
                        <MudSelectItem Value="@Guid.Empty" Disabled="true">
                            ── @cicle.Nom ──
                        </MudSelectItem>
                        @foreach (var curs in cicle.Cursos)
                        {
                            <MudSelectItem Value="@curs.Id">@curs.Nom</MudSelectItem>
                        }
                    }
                </MudSelect>
            }
            <MudTextField @bind-Value="_formGrupLletra"
                Label="Lletra del grup (A, B... o buit per a infantil)"
                Variant="Variant.Outlined"
                HelperText="Deixa buit si el curs té un sol grup"
                ReadOnly="_editantGrup != null" />
            <MudSelect T="Guid?" @bind-Value="_formGrupTutorId"
                Label="Tutor/a assignat/da" Variant="Variant.Outlined"
                Clearable="true" HelperText="Selecciona el/la mestre/a responsable del grup">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">— Sense tutor —</MudSelectItem>
                @foreach (var u in _mestres)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)u.Id)">@u.NomComplet</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogGrupObert = false" Variant="Variant.Text">Cancel·lar</MudButton>
        <MudButton OnClick="DesarGrupAsync"
            Variant="Variant.Filled" Color="Color.Primary"
            Disabled="_desant">
            @(_editantGrup == null ? "Crear grup" : "Desar canvis")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog crear/editar alumne -->
<MudDialog @bind-Visible="_dialogObert" Options="@_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(_editantAlumne == null ? "Nou alumne" : "Editar alumne")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_formNom" Label="Nom"
                        Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_formCognom1" Label="Primer cognom"
                        Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_formCognom2" Label="Segon cognom"
                        Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_formDataNaixement"
                        Label="Data de naixement"
                        Variant="Variant.Outlined"
                        DateFormat="dd/MM/yyyy"
                        Editable="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudNumericField T="int" @bind-Value="_formOrdreFusteta"
                        Label="Ordre Fusteta"
                        Variant="Variant.Outlined" Min="0" Max="99" />
                </MudItem>
                @if (_editantAlumne != null)
                {
                    <MudItem xs="12" sm="3">
                        <MudSwitch @bind-Value="_formEsActiu"
                            Color="Color.Primary"
                            Label="@(_formEsActiu ? "Actiu" : "Inactiu")" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudDivider Class="my-1" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color:#4A5568">
                            Foto de l'alumne/a
                        </MudText>
                        <div class="d-flex align-center gap-3">
                            @if (!string.IsNullOrEmpty(_editantAlumne.FotoPath))
                            {
                                <img src="@_editantAlumne.FotoPath" alt=""
                                    style="width:64px;height:64px;border-radius:50%;object-fit:cover;flex-shrink:0" />
                            }
                            else
                            {
                                <MudAvatar Color="Color.Primary" Size="Size.Large"
                                    Style="width:64px;height:64px;font-size:1.25rem;font-weight:700">
                                    @_editantAlumne.Inicials
                                </MudAvatar>
                            }
                            <div>
                                @if (!_pujantFoto)
                                {
                                    <InputFile id="inputFotoAlumne" OnChange="PujarFotoAlumneAsync"
                                        accept="image/jpeg,image/png,image/webp"
                                        style="display:none" />
                                }
                                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                    StartIcon="@Icons.Material.Filled.PhotoCamera"
                                    OnClick="@(() => { })"
                                    HtmlTag="label" for="inputFotoAlumne"
                                    Disabled="_pujantFoto">
                                    @if (_pujantFoto)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                    }
                                    Canviar foto
                                </MudButton>
                                <MudText Typo="Typo.caption" Style="color:#A0AEC0;display:block;margin-top:4px">
                                    JPEG, PNG o WebP · màx. 2 MB
                                </MudText>
                            </div>
                        </div>
                    </MudItem>
                }
            </MudGrid>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogObert = false" Variant="Variant.Text">
            Cancel·lar
        </MudButton>
        <MudButton OnClick="DesarAlumneAsync"
            Variant="Variant.Filled" Color="Color.Primary"
            Disabled="_desant">
            @(_editantAlumne == null ? "Afegir alumne" : "Desar canvis")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<GrupModel> _grups = [];
    private List<CicleModel> _cicles = [];
    private List<AlumneModel> _alumnes = [];
    private List<UsuariModel> _mestres = [];
    private Guid? _grupSeleccionat;
    private bool _carregantAlumnes;
    private bool _dialogObert;
    private bool _dialogGrupObert;
    private bool _desant;
    private AlumneModel? _editantAlumne;
    private GrupModel? _editantGrup;

    // Confirmació
    private MudMessageBox? _confirmBox;
    private string _confirmMissatge = string.Empty;
    private bool _pujantFoto;

    // Formulari grup
    private Guid _formGrupCursId = Guid.Empty;
    private string _formGrupLletra = string.Empty;
    private Guid? _formGrupTutorId;

    // Formulari alumne
    private string _formNom = string.Empty;
    private string _formCognom1 = string.Empty;
    private string? _formCognom2;
    private DateTime? _formDataNaixement;
    private int _formOrdreFusteta;
    private bool _formEsActiu = true;

    // Mestres autoritzats
    private bool _dialogMestresObert;
    private GrupModel? _grupMestresActual;
    private List<UsuariModel> _mestresGrup = [];
    private Guid _mestreAfegirId;

    // Importació Excel
    private bool _dialogExcelObert;
    private bool _importantExcel;
    private ImportarAlumnesResultModel? _resultatImportacio;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseButton = true
    };

    private readonly DialogOptions _dialogOptionsSmall = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseButton = true
    };

    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Set(
            new("Inici", "/"),
            new("Configuració", null, true),
            new("Alumnes i grups", null, true));
        var tGrups = ConfiguracioService.GetGrupsConfiguracioAsync();
        var tUsuaris = ConfiguracioService.GetUsuarisAsync();
        await Task.WhenAll(tGrups, tUsuaris);
        _grups = tGrups.Result;
        _mestres = tUsuaris.Result
            .Where(u => u.EsActiu)
            .OrderBy(u => u.NomComplet).ToList();
        _cicles = await GrupService.GetCiclesAsync();
    }

    private void ObrirCrearGrup()
    {
        _editantGrup = null;
        _formGrupCursId = Guid.Empty;
        _formGrupLletra = string.Empty;
        _formGrupTutorId = null;
        _dialogGrupObert = true;
    }

    private void ObrirEditarGrup(GrupModel grup)
    {
        _editantGrup = grup;
        _formGrupLletra = grup.Lletra;
        _formGrupTutorId = grup.TutorId;
        _dialogGrupObert = true;
    }

    private async Task DesarGrupAsync()
    {
        _desant = true;
        bool ok;
        string? error;

        if (_editantGrup == null)
        {
            if (_formGrupCursId == Guid.Empty)
            {
                Snackbar.Add("Selecciona un curs", Severity.Warning);
                _desant = false;
                return;
            }
            (ok, error) = await ConfiguracioService.CrearGrupAsync(new CrearGrupModel
            {
                CursId = _formGrupCursId,
                Lletra = _formGrupLletra.Trim(),
                TutorId = _formGrupTutorId
            });
        }
        else
        {
            (ok, error) = await ConfiguracioService.ActualitzarGrupAsync(_editantGrup.Id, new ActualitzarGrupModel
            {
                Lletra = _formGrupLletra.Trim(),
                TutorId = _formGrupTutorId
            });
        }

        if (ok)
        {
            Snackbar.Add(_editantGrup == null ? "Grup creat correctament" : "Grup actualitzat correctament", Severity.Success);
            _dialogGrupObert = false;
            _grups = await ConfiguracioService.GetGrupsConfiguracioAsync();
        }
        else
        {
            Snackbar.Add(error ?? "Error al desar el grup", Severity.Error);
        }
        _desant = false;
    }

    private async Task EsborrarGrupAsync(Guid id)
    {
        var grup = _grups.FirstOrDefault(g => g.Id == id);
        var nomGrup = grup?.NomComplet ?? "aquest grup";

        _confirmMissatge = $"Segur que vols esborrar el grup «{nomGrup}»? Aquesta acció no es pot desfer.";
        var confirm = await _confirmBox!.ShowAsync();
        if (confirm != true) return;

        var (ok, error) = await ConfiguracioService.EsborrarGrupAsync(id);
        if (ok)
        {
            Snackbar.Add("Grup esborrat correctament", Severity.Success);
            _grupSeleccionat = null;
            _alumnes = [];
            _grups = await ConfiguracioService.GetGrupsConfiguracioAsync();
        }
        else
        {
            Snackbar.Add(error ?? "Error al esborrar el grup", Severity.Error);
        }
    }

    private async Task GrupCanviatAsync(Guid? grupId)
    {
        _grupSeleccionat = grupId;
        if (!grupId.HasValue) return;

        _carregantAlumnes = true;
        _alumnes = await AlumnesService.GetAlumnesPerGrupAsync(grupId.Value);
        _carregantAlumnes = false;
    }

    private void ObrirCrearAlumne()
    {
        _editantAlumne = null;
        _formNom = string.Empty;
        _formCognom1 = string.Empty;
        _formCognom2 = null;
        _formDataNaixement = null;
        _formOrdreFusteta = _alumnes.Count + 1;
        _formEsActiu = true;
        _dialogObert = true;
    }

    private void ObrirEditarAlumne(AlumneModel a)
    {
        _editantAlumne = a;
        _formNom = a.Nom;
        _formCognom1 = a.Cognom1;
        _formCognom2 = a.Cognom2;
        _formDataNaixement = a.DataNaixement.HasValue
            ? a.DataNaixement.Value.ToDateTime(TimeOnly.MinValue)
            : null;
        _formOrdreFusteta = a.OrdreFusteta;
        _formEsActiu = a.EsActiu;
        _dialogObert = true;
    }

    private async Task PujarFotoAlumneAsync(InputFileChangeEventArgs e)
    {
        if (_editantAlumne == null) return;
        _pujantFoto = true;
        try
        {
            var (ok, fotoPath, error) = await AlumnesService.PujarFotoAlumneAsync(_editantAlumne.Id, e.File);
            if (ok && fotoPath != null)
            {
                _editantAlumne = _editantAlumne with { FotoPath = fotoPath };
                var idx = _alumnes.FindIndex(a => a.Id == _editantAlumne.Id);
                if (idx >= 0) _alumnes[idx] = _editantAlumne;
                Snackbar.Add("Foto actualitzada correctament", Severity.Success);
            }
            else
            {
                Snackbar.Add(error ?? "Error al pujar la foto", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("No s'ha pogut pujar la foto. Comprova la connexió.", Severity.Error);
        }
        finally
        {
            _pujantFoto = false;
        }
    }

    private async Task DesarAlumneAsync()
    {
        if (string.IsNullOrWhiteSpace(_formNom) || string.IsNullOrWhiteSpace(_formCognom1))
        {
            Snackbar.Add("El nom i el primer cognom són obligatoris", Severity.Warning);
            return;
        }

        _desant = true;

        if (_editantAlumne == null)
        {
            var (ok, error) = await AlumnesService.CrearAlumneAsync(new CrearAlumneModel
            {
                Nom = _formNom,
                Cognom1 = _formCognom1,
                Cognom2 = _formCognom2,
                DataNaixement = _formDataNaixement.HasValue
                    ? DateOnly.FromDateTime(_formDataNaixement.Value)
                    : null,
                GrupId = _grupSeleccionat!.Value,
                OrdreFusteta = _formOrdreFusteta
            });

            if (ok)
            {
                Snackbar.Add("Alumne afegit correctament", Severity.Success);
                _dialogObert = false;
                await GrupCanviatAsync(_grupSeleccionat);
            }
            else
            {
                Snackbar.Add(error ?? "Error al crear l'alumne", Severity.Error);
            }
        }
        else
        {
            var (ok, error) = await AlumnesService.ActualitzarAlumneAsync(
                _editantAlumne.Id,
                new ActualitzarAlumneModel
                {
                    Nom = _formNom,
                    Cognom1 = _formCognom1,
                    Cognom2 = _formCognom2,
                    DataNaixement = _formDataNaixement.HasValue
                        ? DateOnly.FromDateTime(_formDataNaixement.Value)
                        : null,
                    OrdreFusteta = _formOrdreFusteta,
                    EsActiu = _formEsActiu
                });

            if (ok)
            {
                Snackbar.Add("Alumne actualitzat correctament", Severity.Success);
                _dialogObert = false;
                await GrupCanviatAsync(_grupSeleccionat);
            }
            else
            {
                Snackbar.Add(error ?? "Error al actualitzar l'alumne", Severity.Error);
            }
        }

        _desant = false;
    }

    // ── Mestres autoritzats ──────────────────────────────────

    private IEnumerable<UsuariModel> _mestresDisponibles =>
        _mestres.Where(m => m.Id != (_grupMestresActual?.TutorId ?? Guid.Empty)
                         && !_mestresGrup.Any(mg => mg.Id == m.Id));

    private async Task ObrirMestresGrup(GrupModel grup)
    {
        _grupMestresActual = grup;
        _mestreAfegirId = Guid.Empty;
        _mestresGrup = await ConfiguracioService.GetMestresGrupAsync(grup.Id);
        _dialogMestresObert = true;
    }

    private async Task AfegirMestreGrupAsync()
    {
        if (_grupMestresActual == null || _mestreAfegirId == Guid.Empty) return;
        _desant = true;

        var (ok, error) = await ConfiguracioService.AfegirMestreGrupAsync(_grupMestresActual.Id, _mestreAfegirId);
        if (ok)
        {
            Snackbar.Add("Mestre autoritzat correctament", Severity.Success);
            _mestresGrup = await ConfiguracioService.GetMestresGrupAsync(_grupMestresActual.Id);
            _mestreAfegirId = Guid.Empty;
        }
        else
        {
            Snackbar.Add(error ?? "Error en autoritzar el mestre", Severity.Error);
        }
        _desant = false;
    }

    private async Task TreureMestreGrupAsync(Guid mestreId)
    {
        if (_grupMestresActual == null) return;
        var (ok, error) = await ConfiguracioService.TreureMestreGrupAsync(_grupMestresActual.Id, mestreId);
        if (ok)
        {
            Snackbar.Add("Mestre tret del grup", Severity.Success);
            _mestresGrup = await ConfiguracioService.GetMestresGrupAsync(_grupMestresActual.Id);
        }
        else
        {
            Snackbar.Add(error ?? "Error en treure el mestre", Severity.Error);
        }
    }

    // ── Importació Excel ─────────────────────────────────────

    private void ObrirImportarExcel()
    {
        _resultatImportacio = null;
        _dialogExcelObert = true;
    }

    private void TancarDialogExcel()
    {
        _dialogExcelObert = false;
        if (_resultatImportacio?.Importats > 0)
            _ = GrupCanviatAsync(_grupSeleccionat);
    }

    private async Task ImportarExcelAsync(InputFileChangeEventArgs e)
    {
        if (!_grupSeleccionat.HasValue) return;
        _importantExcel = true;
        _resultatImportacio = null;

        try
        {
            var (ok, resultat, error) = await ConfiguracioService.ImportarAlumnesExcelAsync(
                _grupSeleccionat.Value, e.File);

            if (ok && resultat != null)
            {
                _resultatImportacio = resultat;
                _grups = await ConfiguracioService.GetGrupsConfiguracioAsync();
            }
            else
            {
                Snackbar.Add(error ?? "Error en importar el fitxer Excel", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("No s'ha pogut processar el fitxer Excel", Severity.Error);
        }
        finally
        {
            _importantExcel = false;
        }
    }
}

@page "/configuracio/sessions"
@attribute [Authorize(Roles = "EquipDirectiu")]
@inject ConfiguracioService ConfiguracioService
@inject GrupService GrupService
@inject ISnackbar Snackbar
@inject BreadcrumbService BreadcrumbService

<PageTitle>Traçabilitat — Configuració</PageTitle>

<div class="mb-5">
    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">Traçabilitat d'assistències</MudText>
    <MudText Typo="Typo.subtitle1" Style="color:#4A5568">
        Historial de sessions introduïdes: qui ha passat llista, quan i amb quants alumnes absents
    </MudText>
</div>

@if (_carregant)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_anys.Count == 0)
{
    <MudAlert Severity="Severity.Warning">No hi ha cap any acadèmic configurat.</MudAlert>
}
else
{
    <MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px">

        <!-- Fila 1: Any acadèmic + resum -->
        <div class="d-flex align-center gap-4 flex-wrap mb-3">
            <MudSelect T="Guid" Value="_anySeleccionat"
                Label="Any acadèmic" Variant="Variant.Outlined"
                Style="max-width:220px" Dense="true"
                ValueChanged="AnyCanviatAsync">
                @foreach (var any in _anys)
                {
                    <MudSelectItem T="Guid" Value="@any.Id">
                        @any.Nom @(any.EsActiu ? "✓" : "")
                    </MudSelectItem>
                }
            </MudSelect>
            <MudSpacer />
            <MudText Typo="Typo.caption" Style="color:#718096">
                @_total sessions · Pàgina @_pagina de @PaginesTotal
            </MudText>
        </div>

        <!-- Fila 2: Filtres -->
        <div class="d-flex align-center gap-3 flex-wrap mb-3">
            <!-- Grup -->
            <MudSelect T="Guid?" Value="_filtreGrupId"
                Label="Grup" Variant="Variant.Outlined"
                Style="min-width:160px;max-width:200px" Dense="true" Clearable="true"
                ValueChanged="FiltreGrupCanviatAsync">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">Tots els grups</MudSelectItem>
                @foreach (var g in _grups)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)g.Id)">@g.NomComplet</MudSelectItem>
                }
            </MudSelect>

            <!-- Mestre/a -->
            <MudSelect T="Guid?" Value="_filtreMestreId"
                Label="Mestre/a" Variant="Variant.Outlined"
                Style="min-width:160px;max-width:220px" Dense="true" Clearable="true"
                ValueChanged="FiltreMestreCanviatAsync">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">Tots els mestres</MudSelectItem>
                @foreach (var u in _usuaris)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)u.Id)">@u.NomComplet</MudSelectItem>
                }
            </MudSelect>

            <!-- Franja horària -->
            <MudSelect T="Guid?" Value="_filtreFranjaId"
                Label="Franja" Variant="Variant.Outlined"
                Style="min-width:140px;max-width:180px" Dense="true" Clearable="true"
                ValueChanged="FiltreFranjaCanviatAsync">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">Totes les franges</MudSelectItem>
                @foreach (var f in _franjes)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)f.Id)">@f.Nom</MudSelectItem>
                }
            </MudSelect>

            <!-- Rang de dates -->
            <MudDatePicker Date="_filtreDataInici"
                Label="Des de" Variant="Variant.Outlined"
                DateFormat="dd/MM/yyyy" Dense="true"
                Style="max-width:160px" Clearable="true"
                DateChanged="FiltreDataIniciCanviada" />
            <MudDatePicker Date="_filtreDataFi"
                Label="Fins a" Variant="Variant.Outlined"
                DateFormat="dd/MM/yyyy" Dense="true"
                Style="max-width:160px" Clearable="true"
                DateChanged="FiltreDataFiCanviada" />

            <!-- Botó netejar filtres -->
            @if (TeFiltresActius)
            {
                <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                    StartIcon="@Icons.Material.Filled.FilterAltOff"
                    OnClick="NetejarFiltresAsync">
                    Netejar filtres
                </MudButton>
            }
        </div>

        @if (_sessions.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No hi ha sessions que coincideixin amb els filtres seleccionats.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_sessions" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>Data</MudTh>
                    <MudTh>Grup</MudTh>
                    <MudTh>Franja</MudTh>
                    <MudTh>Mestre/a</MudTh>
                    <MudTh Style="text-align:center">Presents</MudTh>
                    <MudTh Style="text-align:center">Absents</MudTh>
                    <MudTh Style="text-align:center">Tard</MudTh>
                    <MudTh Style="text-align:center">Total</MudTh>
                    <MudTh>Hora entrada</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Style="font-weight:500">
                            @context.Data.ToString("dd/MM/yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd>@context.GrupNom</MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption">@context.FranjaNom</MudText>
                    </MudTd>
                    <MudTd>@context.MestreNomComplet</MudTd>
                    <MudTd Style="text-align:center">
                        @if (context.NombrePresents > 0)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">
                                @context.NombrePresents
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="color:#A0AEC0">0</MudText>
                        }
                    </MudTd>
                    <MudTd Style="text-align:center">
                        @if (context.NombreAbsents > 0)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">
                                @context.NombreAbsents
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="color:#A0AEC0">0</MudText>
                        }
                    </MudTd>
                    <MudTd Style="text-align:center">
                        @if (context.NombreTard > 0)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                                @context.NombreTard
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="color:#A0AEC0">0</MudText>
                        }
                    </MudTd>
                    <MudTd Style="text-align:center">
                        <MudText Typo="Typo.caption">@context.NombreTotal</MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption" Style="color:#718096">
                            @context.DegatAt.ToLocalTime().ToString("HH:mm")
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Paginació -->
            @if (PaginesTotal > 1)
            {
                <div class="d-flex justify-center mt-3">
                    <MudPagination Count="PaginesTotal" Selected="_pagina"
                        Color="Color.Primary" BoundaryCount="1" MiddleCount="3"
                        SelectedChanged="PaginaCanviadaAsync" />
                </div>
            }
        }
    </MudPaper>
}

@code {
    private List<AnyAcademicModel> _anys = [];
    private List<GrupModel> _grups = [];
    private List<UsuariModel> _usuaris = [];
    private List<FranjaHorariaModel> _franjes = [];

    private Guid _anySeleccionat;
    private Guid? _filtreGrupId;
    private Guid? _filtreMestreId;
    private Guid? _filtreFranjaId;
    private DateTime? _filtreDataInici;
    private DateTime? _filtreDataFi;

    private List<SessioTraçabilitatModel> _sessions = [];
    private int _total;
    private int _pagina = 1;
    private const int MidaPagina = 50;
    private bool _carregant = true;

    private int PaginesTotal => (int)Math.Ceiling((double)_total / MidaPagina);
    private bool TeFiltresActius => _filtreGrupId.HasValue || _filtreMestreId.HasValue
        || _filtreFranjaId.HasValue || _filtreDataInici.HasValue || _filtreDataFi.HasValue;

    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Set(
            new("Inici", "/"),
            new("Configuració", null, true),
            new("Traçabilitat", null, true));

        var tAnys = ConfiguracioService.GetAnysAcademicsAsync();
        var tGrups = ConfiguracioService.GetGrupsConfiguracioAsync();
        var tUsuaris = ConfiguracioService.GetUsuarisAsync();
        var tFranjes = GrupService.GetFranjesAsync();
        await Task.WhenAll(tAnys, tGrups, tUsuaris, tFranjes);

        _anys = tAnys.Result;
        _grups = tGrups.Result.OrderBy(g => g.NomComplet).ToList();
        _usuaris = tUsuaris.Result.Where(u => u.EsActiu).OrderBy(u => u.NomComplet).ToList();
        _franjes = tFranjes.Result.OrderBy(f => f.Ordre).ToList();

        var actiu = _anys.FirstOrDefault(a => a.EsActiu) ?? _anys.FirstOrDefault();
        if (actiu != null)
        {
            _anySeleccionat = actiu.Id;
            await CarregarSessionsAsync();
        }
        _carregant = false;
    }

    private async Task AnyCanviatAsync(Guid id)
    {
        _anySeleccionat = id;
        _pagina = 1;
        await CarregarSessionsAsync();
    }

    private async Task FiltreGrupCanviatAsync(Guid? id)
    {
        _filtreGrupId = id;
        _pagina = 1;
        await CarregarSessionsAsync();
    }

    private async Task FiltreMestreCanviatAsync(Guid? id)
    {
        _filtreMestreId = id;
        _pagina = 1;
        await CarregarSessionsAsync();
    }

    private async Task FiltreFranjaCanviatAsync(Guid? id)
    {
        _filtreFranjaId = id;
        _pagina = 1;
        await CarregarSessionsAsync();
    }

    private async Task FiltreDataIniciCanviada(DateTime? data)
    {
        _filtreDataInici = data;
        _pagina = 1;
        await CarregarSessionsAsync();
    }

    private async Task FiltreDataFiCanviada(DateTime? data)
    {
        _filtreDataFi = data;
        _pagina = 1;
        await CarregarSessionsAsync();
    }

    private async Task NetejarFiltresAsync()
    {
        _filtreGrupId = null;
        _filtreMestreId = null;
        _filtreFranjaId = null;
        _filtreDataInici = null;
        _filtreDataFi = null;
        _pagina = 1;
        await CarregarSessionsAsync();
    }

    private async Task PaginaCanviadaAsync(int pagina)
    {
        _pagina = pagina;
        await CarregarSessionsAsync();
    }

    private async Task CarregarSessionsAsync()
    {
        if (_anySeleccionat == Guid.Empty) return;
        var dataInici = _filtreDataInici.HasValue
            ? DateOnly.FromDateTime(_filtreDataInici.Value) : (DateOnly?)null;
        var dataFi = _filtreDataFi.HasValue
            ? DateOnly.FromDateTime(_filtreDataFi.Value) : (DateOnly?)null;
        var data = await ConfiguracioService.GetSessionsAsync(
            _anySeleccionat, _pagina, MidaPagina,
            _filtreGrupId, _filtreMestreId, dataInici, dataFi, _filtreFranjaId);
        _sessions = data.Sessions;
        _total = data.Total;
        StateHasChanged();
    }
}

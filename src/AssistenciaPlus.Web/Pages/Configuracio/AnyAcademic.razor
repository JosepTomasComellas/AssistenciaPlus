@page "/configuracio/any-academic"
@attribute [Authorize(Roles = "EquipDirectiu")]
@inject ConfiguracioService ConfiguracioService
@inject ISnackbar Snackbar
@inject BreadcrumbService BreadcrumbService

<PageTitle>Any acadèmic — Configuració</PageTitle>

<div class="mb-5">
    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">Any acadèmic</MudText>
    <MudText Typo="Typo.subtitle1" Style="color:#4A5568">
        Gestió dels anys acadèmics i trimestres
    </MudText>
</div>

@if (_carregant)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else
{
    <!-- Anys acadèmics existents -->
    <MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600">Anys acadèmics</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                StartIcon="@Icons.Material.Filled.Add"
                OnClick="ObrirCrearAnyAcademic">
                Nou any acadèmic
            </MudButton>
        </div>

        @if (_anys.Count == 0)
        {
            <MudAlert Severity="Severity.Warning">
                No hi ha cap any acadèmic configurat. Crea el primer any acadèmic per poder gestionar grups i alumnes.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_anys" Hover="true" Dense="true">
                <HeaderContent>
                    <MudTh>Any acadèmic</MudTh>
                    <MudTh>Inici</MudTh>
                    <MudTh>Fi</MudTh>
                    <MudTh>1r Trimestre</MudTh>
                    <MudTh>2n Trimestre</MudTh>
                    <MudTh>3r Trimestre</MudTh>
                    <MudTh Style="text-align:center">Estat</MudTh>
                    <MudTh Style="text-align:center">Activar</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Style="@(context.EsActiu ? "font-weight:700" : "font-weight:400")">
                            @context.Nom
                        </MudText>
                    </MudTd>
                    <MudTd>@context.DataInici.ToString("dd/MM/yyyy")</MudTd>
                    <MudTd>@context.DataFi.ToString("dd/MM/yyyy")</MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption">
                            @context.IniciFT1.ToString("dd/MM") – @context.FiT1.ToString("dd/MM/yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption">
                            @context.IniciFT2.ToString("dd/MM") – @context.FiT2.ToString("dd/MM/yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption">
                            @context.IniciFT3.ToString("dd/MM") – @context.FiT3.ToString("dd/MM/yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd Style="text-align:center">
                        @if (context.EsActiu)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Actiu</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small">Inactiu</MudChip>
                        }
                    </MudTd>
                    <MudTd Style="text-align:center">
                        @if (!context.EsActiu)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                Size="Size.Small"
                                OnClick="() => ActivarAnyAcademicAsync(context.Id)">
                                Activar
                            </MudButton>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <!-- Estructura de cicles i cursos (editable) -->
    <MudPaper Elevation="1" Class="pa-4" Style="border-radius:12px">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600">Estructura de cicles i cursos</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                StartIcon="@Icons.Material.Filled.AddCircleOutline"
                OnClick="ObrirCrearCicle">
                Nou cicle
            </MudButton>
        </div>

        @if (_cicles.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No hi ha cap cicle configurat. Crea el primer cicle per poder afegir cursos i grups.
            </MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var cicle in _cicles.OrderBy(c => c.Ordre))
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudPaper Elevation="0" Class="pa-3"
                            Style="border:1px solid #E2E8F0;border-radius:8px;height:100%">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600;color:#2E7D32">
                                    @cicle.Nom
                                </MudText>
                                <div class="d-flex gap-1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                        Size="Size.Small" Color="Color.Primary"
                                        OnClick="() => ObrirEditarCicle(cicle)"
                                        title="Editar cicle" />
                                    @if (cicle.Cursos.Count == 0)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                            Size="Size.Small" Color="Color.Error"
                                            OnClick="() => EsborrarCicleAsync(cicle)"
                                            title="Esborrar cicle buit" />
                                    }
                                </div>
                            </div>

                            @foreach (var curs in cicle.Cursos.OrderBy(c => c.Ordre))
                            {
                                <div class="d-flex align-center justify-space-between mt-1"
                                    Style="border-bottom:1px solid #F7FAFC;padding-bottom:4px">
                                    <div class="d-flex align-center gap-1">
                                        <MudText Typo="Typo.body2">@curs.Nom</MudText>
                                        <MudText Typo="Typo.caption" Style="color:#A0AEC0">
                                            (@curs.Codi)
                                        </MudText>
                                        @if (curs.UsaModeFusteta)
                                        {
                                            <MudChip T="string" Color="Color.Info" Size="Size.Small"
                                                Style="height:16px;font-size:0.6rem;padding:0 4px">
                                                F
                                            </MudChip>
                                        }
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                        Size="Size.Small" Color="Color.Default"
                                        OnClick="() => ObrirEditarCurs(cicle, curs)"
                                        title="Editar curs" />
                                </div>
                            }

                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                Size="Size.Small" Class="mt-2"
                                StartIcon="@Icons.Material.Filled.Add"
                                OnClick="() => ObrirCrearCurs(cicle)">
                                Afegir curs
                            </MudButton>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudPaper>
}

<!-- Confirmació d'esborrat -->
<MudMessageBox @ref="_confirmBox" Title="Confirmar esborrat" CancelText="Cancel·lar">
    <MessageContent>@_confirmMissatge</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
            StartIcon="@Icons.Material.Filled.DeleteForever">
            Sí, esborrar
        </MudButton>
    </YesButton>
</MudMessageBox>

<!-- Dialog: Nou any acadèmic -->
<MudDialog @bind-Visible="_dialogObert" Options="@_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Nou any acadèmic</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_formNom" Label="Nom (ex: 2026-2027)"
                Variant="Variant.Outlined" Required="true" />
            <MudGrid>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formDataInici" Label="Data d'inici"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formDataFi" Label="Data de fi"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
            </MudGrid>
            <MudText Typo="Typo.subtitle2" Style="font-weight:600;margin-top:8px">Trimestres</MudText>
            <MudGrid>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formIniciT1" Label="Inici 1r trimestre"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formFiT1" Label="Fi 1r trimestre"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formIniciT2" Label="Inici 2n trimestre"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formFiT2" Label="Fi 2n trimestre"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formIniciT3" Label="Inici 3r trimestre"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_formFiT3" Label="Fi 3r trimestre"
                        Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
            </MudGrid>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogObert = false" Variant="Variant.Text">Cancel·lar</MudButton>
        <MudButton OnClick="DesarAnyAcademicAsync"
            Variant="Variant.Filled" Color="Color.Primary"
            Disabled="_desant">
            Crear any acadèmic
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog: Cicle (crear/editar) -->
<MudDialog @bind-Visible="_dialogCicleObert" Options="@_dialogOptionsSmall">
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(_editantCicle == null ? "Nou cicle" : "Editar cicle")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_formCicleNom" Label="Nom del cicle"
                Variant="Variant.Outlined" Required="true"
                HelperText="Ex: Cicle Infantil, Cicle Inicial..." />
            <MudNumericField T="int" @bind-Value="_formCicleOrdre"
                Label="Ordre de visualització"
                Variant="Variant.Outlined" Min="1" Max="99" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogCicleObert = false" Variant="Variant.Text">Cancel·lar</MudButton>
        <MudButton OnClick="DesarCicleAsync"
            Variant="Variant.Filled" Color="Color.Primary"
            Disabled="_desant">
            @(_editantCicle == null ? "Crear cicle" : "Desar canvis")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog: Curs (crear/editar) -->
<MudDialog @bind-Visible="_dialogCursObert" Options="@_dialogOptionsSmall">
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(_editantCurs == null ? $"Nou curs a {_cicleActualCurs?.Nom}" : "Editar curs")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_formCursNom" Label="Nom del curs"
                Variant="Variant.Outlined" Required="true"
                HelperText="Ex: Infantil 3, Primer, Segon..." />
            <MudTextField @bind-Value="_formCursCodi" Label="Codi curt"
                Variant="Variant.Outlined"
                HelperText="Ex: I3, 1r, 2n... (per a informes)" />
            <MudNumericField T="int" @bind-Value="_formCursOrdre"
                Label="Ordre dins del cicle"
                Variant="Variant.Outlined" Min="1" Max="99" />
            <MudSwitch @bind-Value="_formCursUsaFusteta"
                Color="Color.Primary"
                Label="@(_formCursUsaFusteta ? "Usa mode Fusteta Digital" : "No usa mode Fusteta")" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogCursObert = false" Variant="Variant.Text">Cancel·lar</MudButton>
        <MudButton OnClick="DesarCursAsync"
            Variant="Variant.Filled" Color="Color.Primary"
            Disabled="_desant">
            @(_editantCurs == null ? "Crear curs" : "Desar canvis")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<AnyAcademicModel> _anys = [];
    private List<CicleModel> _cicles = [];
    private bool _carregant = true;
    private bool _dialogObert;
    private bool _dialogCicleObert;
    private bool _dialogCursObert;
    private bool _desant;

    // Any acadèmic
    private string _formNom = string.Empty;
    private DateTime? _formDataInici;
    private DateTime? _formDataFi;
    private DateTime? _formIniciT1;
    private DateTime? _formFiT1;
    private DateTime? _formIniciT2;
    private DateTime? _formFiT2;
    private DateTime? _formIniciT3;
    private DateTime? _formFiT3;

    // Confirmació
    private MudMessageBox? _confirmBox;
    private string _confirmMissatge = string.Empty;

    // Cicle
    private CicleModel? _editantCicle;
    private string _formCicleNom = string.Empty;
    private int _formCicleOrdre = 1;

    // Curs
    private CicleModel? _cicleActualCurs;
    private CursModel? _editantCurs;
    private string _formCursNom = string.Empty;
    private string _formCursCodi = string.Empty;
    private int _formCursOrdre = 1;
    private bool _formCursUsaFusteta;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseButton = true
    };

    private readonly DialogOptions _dialogOptionsSmall = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseButton = true
    };

    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Set(
            new("Inici", "/"),
            new("Configuració", null, true),
            new("Any acadèmic", null, true));
        _anys = await ConfiguracioService.GetAnysAcademicsAsync();
        _cicles = await ConfiguracioService.GetCiclesAsync();
        _carregant = false;
    }

    private void ObrirCrearAnyAcademic()
    {
        _formNom = string.Empty;
        _formDataInici = new DateTime(DateTime.Today.Year, 9, 8);
        _formDataFi = new DateTime(DateTime.Today.Year + 1, 6, 20);
        _formIniciT1 = new DateTime(DateTime.Today.Year, 9, 8);
        _formFiT1 = new DateTime(DateTime.Today.Year, 12, 20);
        _formIniciT2 = new DateTime(DateTime.Today.Year + 1, 1, 8);
        _formFiT2 = new DateTime(DateTime.Today.Year + 1, 3, 28);
        _formIniciT3 = new DateTime(DateTime.Today.Year + 1, 4, 14);
        _formFiT3 = new DateTime(DateTime.Today.Year + 1, 6, 20);
        _dialogObert = true;
    }

    private async Task ActivarAnyAcademicAsync(Guid id)
    {
        var (ok, error) = await ConfiguracioService.ActivarAnyAcademicAsync(id);
        if (ok)
        {
            Snackbar.Add("Any acadèmic activat correctament", Severity.Success);
            _anys = await ConfiguracioService.GetAnysAcademicsAsync();
        }
        else
        {
            Snackbar.Add(error ?? "Error en activar l'any acadèmic", Severity.Error);
        }
    }

    private async Task DesarAnyAcademicAsync()
    {
        if (string.IsNullOrWhiteSpace(_formNom) || _formDataInici == null || _formDataFi == null)
        {
            Snackbar.Add("El nom i les dates són obligatoris", Severity.Warning);
            return;
        }

        _desant = true;

        var model = new CrearAnyAcademicModel
        {
            Nom = _formNom,
            DataInici = DateOnly.FromDateTime(_formDataInici!.Value),
            DataFi = DateOnly.FromDateTime(_formDataFi!.Value),
            IniciT1 = DateOnly.FromDateTime(_formIniciT1 ?? _formDataInici!.Value),
            FiT1 = DateOnly.FromDateTime(_formFiT1 ?? _formDataFi!.Value),
            IniciT2 = DateOnly.FromDateTime(_formIniciT2 ?? _formDataInici!.Value),
            FiT2 = DateOnly.FromDateTime(_formFiT2 ?? _formDataFi!.Value),
            IniciT3 = DateOnly.FromDateTime(_formIniciT3 ?? _formDataInici!.Value),
            FiT3 = DateOnly.FromDateTime(_formFiT3 ?? _formDataFi!.Value),
        };

        var (ok, error) = await ConfiguracioService.CrearAnyAcademicAsync(model);
        if (ok)
        {
            Snackbar.Add("Any acadèmic creat correctament", Severity.Success);
            _dialogObert = false;
            _anys = await ConfiguracioService.GetAnysAcademicsAsync();
        }
        else
        {
            Snackbar.Add(error ?? "Error en crear l'any acadèmic", Severity.Error);
        }

        _desant = false;
    }

    // ── Cicles ───────────────────────────────────────────────

    private void ObrirCrearCicle()
    {
        _editantCicle = null;
        _formCicleNom = string.Empty;
        _formCicleOrdre = (_cicles.Count > 0 ? _cicles.Max(c => c.Ordre) : 0) + 1;
        _dialogCicleObert = true;
    }

    private void ObrirEditarCicle(CicleModel cicle)
    {
        _editantCicle = cicle;
        _formCicleNom = cicle.Nom;
        _formCicleOrdre = cicle.Ordre;
        _dialogCicleObert = true;
    }

    private async Task DesarCicleAsync()
    {
        if (string.IsNullOrWhiteSpace(_formCicleNom))
        {
            Snackbar.Add("El nom del cicle és obligatori", Severity.Warning);
            return;
        }

        _desant = true;

        if (_editantCicle == null)
        {
            var (ok, error) = await ConfiguracioService.CrearCicleAsync(new CrearCicleModel
            {
                Nom = _formCicleNom,
                Ordre = _formCicleOrdre
            });

            if (ok)
            {
                Snackbar.Add("Cicle creat correctament", Severity.Success);
                _dialogCicleObert = false;
                _cicles = await ConfiguracioService.GetCiclesAsync();
            }
            else
            {
                Snackbar.Add(error ?? "Error en crear el cicle", Severity.Error);
            }
        }
        else
        {
            var (ok, error) = await ConfiguracioService.ActualitzarCicleAsync(_editantCicle.Id, new ActualitzarCicleModel
            {
                Nom = _formCicleNom,
                Ordre = _formCicleOrdre
            });

            if (ok)
            {
                Snackbar.Add("Cicle actualitzat correctament", Severity.Success);
                _dialogCicleObert = false;
                _cicles = await ConfiguracioService.GetCiclesAsync();
            }
            else
            {
                Snackbar.Add(error ?? "Error en actualitzar el cicle", Severity.Error);
            }
        }

        _desant = false;
    }

    private async Task EsborrarCicleAsync(CicleModel cicle)
    {
        _confirmMissatge = $"Segur que vols esborrar el cicle «{cicle.Nom}»? Aquesta acció no es pot desfer.";
        var confirm = await _confirmBox!.ShowAsync();
        if (confirm != true) return;

        var (ok, error) = await ConfiguracioService.EsborrarCicleAsync(cicle.Id);
        if (ok)
        {
            Snackbar.Add("Cicle esborrat correctament", Severity.Success);
            _cicles = await ConfiguracioService.GetCiclesAsync();
        }
        else
        {
            Snackbar.Add(error ?? "Error en esborrar el cicle", Severity.Error);
        }
    }

    // ── Cursos ───────────────────────────────────────────────

    private void ObrirCrearCurs(CicleModel cicle)
    {
        _cicleActualCurs = cicle;
        _editantCurs = null;
        _formCursNom = string.Empty;
        _formCursCodi = string.Empty;
        _formCursOrdre = (cicle.Cursos.Count > 0 ? cicle.Cursos.Max(c => c.Ordre) : 0) + 1;
        _formCursUsaFusteta = false;
        _dialogCursObert = true;
    }

    private void ObrirEditarCurs(CicleModel cicle, CursModel curs)
    {
        _cicleActualCurs = cicle;
        _editantCurs = curs;
        _formCursNom = curs.Nom;
        _formCursCodi = curs.Codi;
        _formCursOrdre = curs.Ordre;
        _formCursUsaFusteta = curs.UsaModeFusteta;
        _dialogCursObert = true;
    }

    private async Task DesarCursAsync()
    {
        if (string.IsNullOrWhiteSpace(_formCursNom) || _cicleActualCurs == null)
        {
            Snackbar.Add("El nom del curs és obligatori", Severity.Warning);
            return;
        }

        _desant = true;

        if (_editantCurs == null)
        {
            var (ok, error) = await ConfiguracioService.CrearCursAsync(_cicleActualCurs.Id, new CrearCursModel
            {
                Nom = _formCursNom,
                Codi = _formCursCodi,
                Ordre = _formCursOrdre,
                UsaModeFusteta = _formCursUsaFusteta
            });

            if (ok)
            {
                Snackbar.Add("Curs creat correctament", Severity.Success);
                _dialogCursObert = false;
                _cicles = await ConfiguracioService.GetCiclesAsync();
            }
            else
            {
                Snackbar.Add(error ?? "Error en crear el curs", Severity.Error);
            }
        }
        else
        {
            var (ok, error) = await ConfiguracioService.ActualitzarCursAsync(
                _cicleActualCurs.Id, _editantCurs.Id, new ActualitzarCursModel
                {
                    Nom = _formCursNom,
                    Codi = _formCursCodi,
                    Ordre = _formCursOrdre,
                    UsaModeFusteta = _formCursUsaFusteta
                });

            if (ok)
            {
                Snackbar.Add("Curs actualitzat correctament", Severity.Success);
                _dialogCursObert = false;
                _cicles = await ConfiguracioService.GetCiclesAsync();
            }
            else
            {
                Snackbar.Add(error ?? "Error en actualitzar el curs", Severity.Error);
            }
        }

        _desant = false;
    }
}

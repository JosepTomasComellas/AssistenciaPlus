@page "/"
@attribute [Authorize]
@inject AuthService AuthService
@inject GrupService GrupService
@inject AssistenciaService AssistenciaService
@inject ConfiguracioService ConfiguracioService
@inject BreadcrumbService BreadcrumbService
@inject NavigationManager Nav

<PageTitle>Inici — AssistenciaPlus</PageTitle>

<!-- Capçalera de benvinguda -->
<div class="mb-6">
    <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">
        Bon @_salutacio, @_nomUsuari
    </MudText>
    <MudText Typo="Typo.subtitle1" Style="color:#4A5568">
        @_dataAvui
    </MudText>
</div>

@if (_carregant)
{
    <MudGrid>
        @for (int i = 0; i < 3; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="160px"
                    Class="rounded-lg" />
            </MudItem>
        }
    </MudGrid>
}
else if (!_grups.Any())
{
    <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0"
        Style="border:2px dashed #E2E8F0;border-radius:12px">
        <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large"
            Style="font-size:3rem;color:#CBD5E0" Class="mb-3" />
        <MudText Typo="Typo.h6" Style="color:#718096">Cap grup assignat</MudText>
        <MudText Typo="Typo.body2" Style="color:#A0AEC0" Align="Align.Center">
            L'equip directiu t'ha d'assignar els grups corresponents
        </MudText>
    </MudPaper>
}
else
{
    <!-- Grups del mestre -->
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight:600">
        Els meus grups avui
    </MudText>
    <MudGrid Class="mb-6">
        @foreach (var grup in _grups)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Class="grup-card cursor-pointer"
                    @onclick="() => NavigarPassarLlista(grup.Id)">
                    <MudCardContent Class="pa-5">
                        <div class="d-flex align-center justify-space-between mb-3">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                Style="font-weight:700;font-size:0.85rem">
                                @grup.CursCodi
                            </MudChip>
                            @if (grup.UsaModeFusteta)
                            {
                                <MudTooltip Text="Mode Fusteta Digital disponible">
                                    <MudIcon Icon="@Icons.Material.Filled.GridView"
                                        Color="Color.Secondary" Size="Size.Small" />
                                </MudTooltip>
                            }
                        </div>
                        <MudText Typo="Typo.h5" Style="font-weight:700;color:#1A2744">
                            @grup.NomComplet
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color:#718096" Class="mt-1">
                            @grup.CicleNom · @grup.NombreAlumnes alumnes
                        </MudText>
                    </MudCardContent>
                    <MudCardActions Class="px-5 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                            StartIcon="@Icons.Material.Filled.Checklist"
                            Size="Size.Small" FullWidth="true"
                            OnClick="@(() => NavigarPassarLlista(grup.Id))">
                            Passar llista
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    <!-- Resum estadístic del dia -->
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight:600">
        Resum d'avui
    </MudText>
    <MudGrid>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="1"
                Style="border-radius:12px;border-left:4px solid #2E7D32">
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">
                    @_grups.Sum(g => g.NombreAlumnes)
                </MudText>
                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                    Total alumnes
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="1"
                Style="border-radius:12px;border-left:4px solid #2E7D32">
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">
                    @_grups.Count
                </MudText>
                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                    Grups
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="1"
                Style="border-radius:12px;border-left:4px solid #E05B1A">
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#E05B1A">
                    @_llistesPassades
                </MudText>
                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                    Llistes fetes
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="1"
                Style="border-radius:12px;border-left:4px solid #C62828">
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#C62828">
                    @_totalAbsents
                </MudText>
                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                    Absències avui
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="1" Class="pa-5 mt-5" Style="border-radius:12px">
        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600">
            Distribució de l'assistència avui
        </MudText>
        @if (_donutData.Length > 0)
        {
            <div class="d-flex justify-center">
                <MudChart T="double" ChartType="ChartType.Donut"
                    InputData="@_donutData"
                    InputLabels="@_donutLabels"
                    Width="280px" Height="280px"
                    ChartOptions="@(new ChartOptions { ChartPalette = _donutPalette })" />
            </div>
        }
        else
        {
            <MudText Typo="Typo.body2" Style="color:#A0AEC0;text-align:center;padding:32px 0">
                Sense dades d'avui. Passa llista per veure l'estadística.
            </MudText>
        }
    </MudPaper>

    <!-- Bloc global: només Equip Directiu -->
    <AuthorizeView Roles="EquipDirectiu">
        <Authorized>
            <div class="mt-6">
                <div class="d-flex align-center justify-space-between mb-3 flex-wrap gap-2">
                    <MudText Typo="Typo.h6" Style="font-weight:600">
                        Vista global del centre avui
                    </MudText>
                    <MudButton Variant="Variant.Text" Size="Size.Small"
                        StartIcon="@Icons.Material.Filled.TableChart"
                        OnClick="@(() => Nav.NavigateTo("/configuracio/sessions"))">
                        Veure traçabilitat completa
                    </MudButton>
                </div>

                @if (_kpis == null)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                }
                else
                {
                    <MudGrid>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-4 text-center" Elevation="1"
                                Style="border-radius:12px;border-left:4px solid #2E7D32">
                                <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">
                                    @_kpis.GrupsAmbLlista
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                                    Grups amb llista
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-4 text-center" Elevation="1"
                                Style="@($"border-radius:12px;border-left:4px solid {(_kpis.GrupsSenseLlista.Count > 0 ? "#C62828" : "#2E7D32")}")">
                                <MudText Typo="Typo.h4" Style="@($"font-weight:700;color:{(_kpis.GrupsSenseLlista.Count > 0 ? "#C62828" : "#2E7D32")}")">
                                    @_kpis.GrupsSenseLlista.Count
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                                    Grups sense llista
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-4 text-center" Elevation="1"
                                Style="border-radius:12px;border-left:4px solid #E05B1A">
                                <MudText Typo="Typo.h4" Style="font-weight:700;color:#E05B1A">
                                    @_kpis.SessionsAvui
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                                    Sessions avui
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-4 text-center" Elevation="1"
                                Style="border-radius:12px;border-left:4px solid #C62828">
                                <MudText Typo="Typo.h4" Style="font-weight:700;color:#C62828">
                                    @_kpis.AbsenciesAvui
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#718096;text-transform:uppercase;letter-spacing:0.05em">
                                    Absències (global)
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @if (_kpis.GrupsSenseLlista.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-4 mt-4" Style="border-radius:12px;border-left:4px solid #C62828">
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Warning"
                                    Style="color:#C62828" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2" Style="font-weight:700;color:#C62828">
                                    Grups sense llista passada avui (@_kpis.GrupsSenseLlista.Count)
                                </MudText>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var nom in _kpis.GrupsSenseLlista)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                        @nom
                                    </MudChip>
                                }
                            </div>
                        </MudPaper>
                    }
                }
            </div>
        </Authorized>
    </AuthorizeView>
}

<style>
    .grup-card {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        border-radius: 12px !important;
    }
    .grup-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(46,125,50,0.15) !important;
    }
    .cursor-pointer { cursor: pointer; }
</style>

@code {
    private List<GrupModel> _grups = [];
    private bool _carregant = true;
    private string _nomUsuari = string.Empty;
    private string _salutacio = "dia";
    private string _dataAvui = string.Empty;
    private int _llistesPassades;
    private int _totalAbsents;
    private int _totalPresents;
    private int _totalTard;
    private double[] _donutData = [];
    private string[] _donutLabels = [];
    private string[] _donutPalette = [];
    private KpisDashboardModel? _kpis;

    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Clear();
        var user = await AuthService.GetCurrentUserAsync();
        _nomUsuari = user?.Nom ?? string.Empty;

        var hora = DateTime.Now.Hour;
        _salutacio = hora < 12 ? "dia" : hora < 20 ? "tarda" : "vespre";

        var info = System.Globalization.CultureInfo.GetCultureInfo("ca-ES");
        _dataAvui = DateTime.Today.ToString("dddd, d MMMM yyyy", info);
        if (_dataAvui.Length > 0)
            _dataAvui = char.ToUpper(_dataAvui[0]) + _dataAvui[1..];

        _grups = await GrupService.GetGrupsAsync();

        var avui = DateOnly.FromDateTime(DateTime.Today);
        foreach (var grup in _grups)
        {
            var registres = await AssistenciaService.GetRegistresAsync(grup.Id, avui);
            if (registres.Any())
            {
                _llistesPassades++;
                var assistencies = registres.SelectMany(r => r.Assistencies).ToList();
                _totalAbsents += assistencies.Count(a => a.Estat == EstatAssistencia.Absent);
                _totalPresents += assistencies.Count(a => a.Estat == EstatAssistencia.Present);
                _totalTard += assistencies.Count(a => a.Estat == EstatAssistencia.Tard);
            }
        }

        var slices = new List<(double Val, string Label)>();
        if (_totalPresents > 0) slices.Add((_totalPresents, $"Presents ({_totalPresents})"));
        if (_totalAbsents > 0) slices.Add((_totalAbsents, $"Absents ({_totalAbsents})"));
        if (_totalTard > 0) slices.Add((_totalTard, $"Tard ({_totalTard})"));
        _donutData = [..slices.Select(s => s.Val)];
        _donutLabels = [..slices.Select(s => s.Label)];
        _donutPalette = slices.Select(s => s.Label.StartsWith("P") ? "#2E7D32" : s.Label.StartsWith("A") ? "#C62828" : "#F57F17").ToArray();

        _carregant = false;

        // KPIs globals (EquipDirectiu): en segon pla, no bloqueja
        _ = CarregarKpisAsync();
    }

    private async Task CarregarKpisAsync()
    {
        try
        {
            var anys = await ConfiguracioService.GetAnysAcademicsAsync();
            var actiu = anys.FirstOrDefault(a => a.EsActiu) ?? anys.FirstOrDefault();
            if (actiu == null) return;
            _kpis = await AssistenciaService.GetKpisDashboardAsync(actiu.Id);
            await InvokeAsync(StateHasChanged);
        }
        catch { /* KPIs no son crítics */ }
    }

    private void NavigarPassarLlista(Guid grupId)
    {
        Nav.NavigateTo($"/passar-llista?grupId={grupId}");
    }
}

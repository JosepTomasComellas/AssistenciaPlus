@page "/passar-llista"
@attribute [Authorize]
@inject GrupService GrupService
@inject AlumnesService AlumnesService
@inject AssistenciaService AssistenciaService
@inject SignalRService SignalR
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject BreadcrumbService BreadcrumbService
@implements IAsyncDisposable

<PageTitle>Passar llista — AssistenciaPlus</PageTitle>

<!-- Capçalera -->
<div class="mb-5 d-flex align-center justify-space-between flex-wrap gap-3">
    <div>
        <MudText Typo="Typo.h4" Style="font-weight:700;color:#2E7D32">Passar llista</MudText>
        <MudText Typo="Typo.subtitle1" Style="color:#4A5568">@_dataAvui</MudText>
    </div>
    <MudDatePicker Date="_dataPickerValue"
        DateChanged="OnDataCanviada"
        Label="Data de la sessió"
        Variant="Variant.Outlined"
        DateFormat="dd/MM/yyyy"
        MaxDate="@DateTime.Today"
        Editable="true"
        Style="max-width:200px" />
</div>

@if (_carregant)
{
    <div class="d-flex justify-center mt-12">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (_fase == Fase.SeleccionarGrup)
{
    <!-- FASE 1: Seleccionar grup -->
    <MudText Typo="Typo.h6" Class="mb-4">Selecciona el grup:</MudText>

    @if (!_grups.Any())
    {
        <MudAlert Severity="Severity.Info">
            No tens cap grup assignat. Contacta amb l'equip directiu.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var grup in _grups)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2" Class="cursor-pointer grup-card"
                        @onclick="() => SeleccionarGrup(grup)">
                        <MudCardContent Class="pa-5">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                Class="mb-2" Style="font-weight:700">
                                @grup.CursCodi
                            </MudChip>
                            <MudText Typo="Typo.h5" Style="font-weight:700">
                                @grup.NomComplet
                            </MudText>
                            <MudText Typo="Typo.body2" Style="color:#718096" Class="mt-1">
                                @grup.NombreAlumnes alumnes · @grup.CicleNom
                            </MudText>
                            @if (grup.UsaModeFusteta)
                            {
                                <MudChip T="string" Size="Size.Small"
                                    Color="Color.Secondary" Class="mt-2"
                                    Icon="@Icons.Material.Filled.GridView">
                                    Mode Fusteta Digital
                                </MudChip>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}
else if (_fase == Fase.SeleccionarFranja)
{
    <!-- FASE 2: Seleccionar franja horària -->

    <MudText Typo="Typo.h6" Class="mb-4">
        Selecciona la franja horària — <strong>@_grupSeleccionat!.NomComplet</strong>
    </MudText>

    <!-- Opcions de període complet -->
    @if (FranjesMati().Count > 1 || FranjesTarda().Count > 1)
    {
        <MudText Typo="Typo.overline" Style="color:#718096" Class="mb-2 d-block">
            Passar tot el període
        </MudText>
        <MudGrid Class="mb-4">
            @if (FranjesMati().Count > 1)
            {
                var fm = FranjesMati();
                var matiPassat = fm.All(f => _registresAvui.Any(r => r.FranjaHorariaId == f.Id));
                <MudItem xs="12" sm="6">
                    <MudCard Elevation="@(matiPassat ? 1 : 3)"
                        Class="@($"cursor-pointer franja-card{(matiPassat ? " franja-feta" : "")}")"
                        Style="border-left:4px solid #3B82F6"
                        @onclick="() => SeleccionarPeriode(true)">
                        <MudCardContent Class="pa-4">
                            <div class="d-flex align-center justify-space-between">
                                <div>
                                    <MudText Typo="Typo.h6" Style="font-weight:700;color:#1D4ED8">
                                        Tot el matí
                                    </MudText>
                                    <MudText Typo="Typo.body2" Style="color:#718096">
                                        @fm.First().HoraInici.ToString("HH\\:mm") –
                                        @fm.Last().HoraFi.ToString("HH\\:mm") ·
                                        @fm.Count franges
                                    </MudText>
                                </div>
                                <MudIcon Icon="@(matiPassat ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.WbSunny)"
                                    Color="@(matiPassat ? Color.Success : Color.Primary)" Size="Size.Medium" />
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
            @if (FranjesTarda().Count > 1)
            {
                var ft = FranjesTarda();
                var tardaPassada = ft.All(f => _registresAvui.Any(r => r.FranjaHorariaId == f.Id));
                <MudItem xs="12" sm="6">
                    <MudCard Elevation="@(tardaPassada ? 1 : 3)"
                        Class="@($"cursor-pointer franja-card{(tardaPassada ? " franja-feta" : "")}")"
                        Style="border-left:4px solid #F59E0B"
                        @onclick="() => SeleccionarPeriode(false)">
                        <MudCardContent Class="pa-4">
                            <div class="d-flex align-center justify-space-between">
                                <div>
                                    <MudText Typo="Typo.h6" Style="font-weight:700;color:#92400E">
                                        Tota la tarda
                                    </MudText>
                                    <MudText Typo="Typo.body2" Style="color:#718096">
                                        @ft.First().HoraInici.ToString("HH\\:mm") –
                                        @ft.Last().HoraFi.ToString("HH\\:mm") ·
                                        @ft.Count franges
                                    </MudText>
                                </div>
                                <MudIcon Icon="@(tardaPassada ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Brightness3)"
                                    Color="@(tardaPassada ? Color.Success : Color.Warning)" Size="Size.Medium" />
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
        <MudText Typo="Typo.overline" Style="color:#718096" Class="mb-2 d-block">
            O selecciona una franja concreta
        </MudText>
    }

    <MudGrid>
        @foreach (var franja in _franjes)
        {
            var jaPassada = _registresAvui.Any(r => r.FranjaHorariaId == franja.Id);
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="@(jaPassada ? 1 : 2)"
                    Class="@($"cursor-pointer franja-card{(jaPassada ? " franja-feta" : "")}")"
                    @onclick="() => SeleccionarFranja(franja)">
                    <MudCardContent Class="pa-5">
                        <div class="d-flex align-center justify-space-between">
                            <div>
                                <MudText Typo="Typo.h6" Style="font-weight:600">
                                    @franja.Nom
                                </MudText>
                                <MudText Typo="Typo.body2" Style="color:#718096">
                                    @franja.HorariDisplay
                                </MudText>
                            </div>
                            @if (jaPassada)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                    Color="Color.Success" Size="Size.Medium" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight"
                                    Color="Color.Default" />
                            }
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
else if (_fase == Fase.PassarLlista)
{
    <!-- FASE 3: Passar llista -->

    <!-- Selector de mode -->
    <div class="d-flex align-center justify-space-between flex-wrap gap-3 mb-5">
        <div>
            <MudText Typo="Typo.h6" Style="font-weight:700">
                @_grupSeleccionat!.NomComplet — @_etiquetaFranja
            </MudText>
            <MudText Typo="Typo.body2" Style="color:#718096">
                @(_franjasADesar.Count > 1
                    ? $"{_franjasADesar.First().HoraInici:HH\\:mm} – {_franjasADesar.Last().HoraFi:HH\\:mm} · {_franjasADesar.Count} franges"
                    : _franjaSeleccionada?.HorariDisplay ?? string.Empty)
                · @_alumnes.Count alumnes
            </MudText>
        </div>
        @if (_grupSeleccionat.UsaModeFusteta)
        {
            <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                <MudButton StartIcon="@Icons.Material.Filled.GridView"
                    Variant="@(_modeFusteta ? Variant.Filled : Variant.Outlined)"
                    OnClick="() => _modeFusteta = true">
                    Fusteta
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.FormatListBulleted"
                    Variant="@(!_modeFusteta ? Variant.Filled : Variant.Outlined)"
                    OnClick="() => _modeFusteta = false">
                    Llista
                </MudButton>
            </MudButtonGroup>
        }
    </div>

    <!-- Acció ràpida: tots presents -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <MudButton Variant="Variant.Outlined" Color="Color.Success"
            StartIcon="@Icons.Material.Filled.DoneAll"
            Size="Size.Small"
            OnClick="MarcarTotsPresents">
            Tots presents
        </MudButton>
        <MudText Typo="Typo.body2" Class="ml-auto align-self-center"
            Style="color:#718096">
            @_inputs.Count(i => i.Estat == EstatAssistencia.Present) presents ·
            <span style="color:#C62828;font-weight:600">
                @_inputs.Count(i => i.Estat == EstatAssistencia.Absent) absents
            </span>
            @if (_inputs.Any(i => i.Estat == EstatAssistencia.Tard))
            {
                <span> · <span style="color:#F57F17">@_inputs.Count(i => i.Estat == EstatAssistencia.Tard) tard</span></span>
            }
        </MudText>
    </div>

    @if (_modeFusteta)
    {
        <!-- MODE FUSTETA DIGITAL -->
        <ModeFusteta Alumnes="_alumnes" Inputs="_inputs" />
    }
    else
    {
        <!-- MODE LLISTA CLÀSSICA -->
        <ModeLlista Alumnes="_alumnes" Inputs="_inputs" />
    }

    <!-- Botonera de desar -->
    <MudPaper Elevation="3" Class="pa-4 mt-5 d-flex align-center gap-3 flex-wrap"
        Style="border-radius:12px;position:sticky;bottom:16px;background:white">
        <MudTextField @bind-Value="_observacioSessio"
            Label="Observació de la sessió (opcional)"
            Variant="Variant.Outlined"
            Lines="1"
            Class="flex-grow-1"
            Adornment="Adornment.Start"
            AdornmentIcon="@Icons.Material.Filled.Note" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
            StartIcon="@Icons.Material.Filled.Save"
            Size="Size.Large"
            OnClick="DesarSessioAsync"
            Disabled="_desant"
            Style="min-width:160px">
            @if (_desant)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Desant...</span>
            }
            else
            {
                <span>Desar assistència</span>
            }
        </MudButton>
    </MudPaper>
}

<style>
    .grup-card, .franja-card {
        border-radius: 12px !important;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .grup-card:hover, .franja-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(46,125,50,0.12) !important;
    }
    .franja-feta {
        opacity: 0.7;
        background: #F7FAF7 !important;
    }
    .cursor-pointer { cursor: pointer; }
</style>

@code {
    private enum Fase { SeleccionarGrup, SeleccionarFranja, PassarLlista }

    private Fase _fase = Fase.SeleccionarGrup;
    private bool _carregant = true;
    private bool _modeFusteta;
    private bool _desant;
    private string _dataAvui = string.Empty;
    private DateOnly _dataSeleccionada = DateOnly.FromDateTime(DateTime.Today);
    private DateTime? _dataPickerValue = DateTime.Today;
    private string? _observacioSessio;

    private List<GrupModel> _grups = [];
    private List<FranjaHorariaModel> _franjes = [];
    private List<AlumneModel> _alumnes = [];
    private List<RegistreAssistenciaModel> _registresAvui = [];
    private List<AssistenciaAlumneInputModel> _inputs = [];

    private GrupModel? _grupSeleccionat;
    private FranjaHorariaModel? _franjaSeleccionada;
    private List<FranjaHorariaModel> _franjasADesar = [];
    private string _etiquetaFranja = string.Empty;


    [SupplyParameterFromQuery]
    private Guid? GrupId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ActualitzarBreadcrumbs();
        ActualitzarDataAvui();

        _grups = await GrupService.GetGrupsAsync();
        _franjes = await GrupService.GetFranjesAsync();

        // Connectar SignalR en segon pla (no bloqueja la càrrega)
        _ = ConnectarSignalRAsync();

        // Si ve un grupId per QueryString, anar directament a la selecció de franja
        if (GrupId.HasValue)
        {
            var grup = _grups.FirstOrDefault(g => g.Id == GrupId.Value);
            if (grup != null)
                await SeleccionarGrup(grup);
        }

        _carregant = false;
    }

    private async Task ConnectarSignalRAsync()
    {
        try
        {
            await SignalR.ConnectarAsync();
            SignalR.AssistenciaActualitzada += OnAssistenciaActualitzada;
            SignalR.Reconnectant += OnReconnectant;
            SignalR.Reconnectat += OnReconnectat;
            SignalR.Desconnectat += OnDesconnectat;
        }
        catch
        {
            // SignalR no és crític — si falla, la pàgina continua funcionant
        }
    }

    private void OnReconnectant()
        => InvokeAsync(() =>
        {
            Snackbar.Add("Connexió perduda. Reconnectant...",
                Severity.Warning, c => { c.Icon = Icons.Material.Filled.WifiOff; c.VisibleStateDuration = 8000; });
        });

    private void OnReconnectat()
        => InvokeAsync(() =>
        {
            Snackbar.Add("Connexió restaurada",
                Severity.Success, c => c.Icon = Icons.Material.Filled.Wifi);
        });

    private void OnDesconnectat()
        => InvokeAsync(() =>
        {
            Snackbar.Add("Sense connexió en temps real. Recarrega la pàgina si cal.",
                Severity.Error, c => { c.Icon = Icons.Material.Filled.WifiOff; c.VisibleStateDuration = 12000; });
        });

    private void OnAssistenciaActualitzada(string sessionId, string groupId)
    {
        if (_grupSeleccionat?.Id.ToString() == groupId)
        {
            Snackbar.Add("Un altre mestre ha actualitzat l'assistència d'aquest grup",
                Severity.Info, c => c.Icon = Icons.Material.Filled.Sync);
            InvokeAsync(StateHasChanged);
        }
    }

    private void ActualitzarDataAvui()
    {
        var info = System.Globalization.CultureInfo.GetCultureInfo("ca-ES");
        _dataAvui = _dataSeleccionada.ToDateTime(TimeOnly.MinValue).ToString("dddd, d MMMM yyyy", info);
        if (_dataAvui.Length > 0)
            _dataAvui = char.ToUpper(_dataAvui[0]) + _dataAvui[1..];
    }

    private async Task OnDataCanviada(DateTime? novaData)
    {
        if (!novaData.HasValue) return;
        _dataSeleccionada = DateOnly.FromDateTime(novaData.Value);
        _dataPickerValue = novaData;
        ActualitzarDataAvui();
        if (_grupSeleccionat != null)
            await SignalR.AbandonarGrupAsync(_grupSeleccionat.Id);
        _grupSeleccionat = null;
        _fase = Fase.SeleccionarGrup;
        ActualitzarBreadcrumbs();
    }

    private async Task SeleccionarGrup(GrupModel grup)
    {
        if (_grupSeleccionat != null)
            await SignalR.AbandonarGrupAsync(_grupSeleccionat.Id);

        _grupSeleccionat = grup;
        _registresAvui = await AssistenciaService.GetRegistresAsync(grup.Id, _dataSeleccionada);

        await SignalR.UnirseAlGrupAsync(grup.Id);
        ActualitzarBreadcrumbs();
        _fase = Fase.SeleccionarFranja;
    }

    private async Task SeleccionarFranja(FranjaHorariaModel franja)
    {
        _franjaSeleccionada = franja;
        _franjasADesar = [franja];
        _etiquetaFranja = franja.Nom;
        await CarregarFase3Async(franja.Id);
    }

    private async Task SeleccionarPeriode(bool esMati)
    {
        var franjesPeriode = _franjes
            .Where(f => f.EsMati == esMati)
            .OrderBy(f => f.Ordre)
            .ToList();

        _franjaSeleccionada = franjesPeriode.FirstOrDefault();
        _franjasADesar = franjesPeriode;
        _etiquetaFranja = esMati ? "Tot el matí" : "Tota la tarda";
        await CarregarFase3Async(franjesPeriode.FirstOrDefault()?.Id ?? Guid.Empty);
    }

    private async Task CarregarFase3Async(Guid franjaReferencia)
    {
        _alumnes = await AlumnesService.GetAlumnesPerGrupAsync(_grupSeleccionat!.Id);

        var registreExistent = franjaReferencia != Guid.Empty
            ? _registresAvui.FirstOrDefault(r => r.FranjaHorariaId == franjaReferencia)
            : null;

        _inputs = _alumnes.Select(a =>
        {
            var assistenciaExistent = registreExistent?.Assistencies
                .FirstOrDefault(x => x.AlumneId == a.Id);

            return new AssistenciaAlumneInputModel
            {
                AlumneId = a.Id,
                Estat = assistenciaExistent?.Estat ?? EstatAssistencia.Present,
                Motiu = assistenciaExistent?.Motiu,
                Torna = assistenciaExistent?.Torna,
                MinutsRetard = assistenciaExistent?.MinutsRetard,
                Observacio = assistenciaExistent?.Observacio
            };
        }).ToList();

        _observacioSessio = registreExistent?.Observacio;
        _modeFusteta = _grupSeleccionat!.UsaModeFusteta;

        ActualitzarBreadcrumbs();
        _fase = Fase.PassarLlista;
    }

    private void MarcarTotsPresents()
    {
        foreach (var input in _inputs)
        {
            input.Estat = EstatAssistencia.Present;
            input.Motiu = null;
            input.Torna = null;
            input.MinutsRetard = null;
            input.Observacio = null;
        }
    }

    private async Task DesarSessioAsync()
    {
        _desant = true;
        try
        {
            string? primerError = null;
            foreach (var franja in _franjasADesar)
            {
                var model = new DesarSessioModel
                {
                    GrupId = _grupSeleccionat!.Id,
                    FranjaHorariaId = franja.Id,
                    Data = _dataSeleccionada,
                    Observacio = _observacioSessio,
                    Assistencies = _inputs
                };

                var (ok, _, error) = await AssistenciaService.DesarSessioAsync(model);
                if (!ok) { primerError = error; break; }
            }

            if (primerError == null)
            {
                var missatge = _franjasADesar.Count > 1
                    ? $"Assistència desada per a {_franjasADesar.Count} franges"
                    : "Assistència desada correctament";
                Snackbar.Add(missatge, Severity.Success,
                    config => config.Icon = Icons.Material.Filled.CheckCircle);
                _registresAvui = await AssistenciaService.GetRegistresAsync(
                    _grupSeleccionat!.Id, _dataSeleccionada);
            }
            else
            {
                Snackbar.Add(primerError ?? "Error al desar l'assistència", Severity.Error);
            }
        }
        finally
        {
            _desant = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        SignalR.AssistenciaActualitzada -= OnAssistenciaActualitzada;
        SignalR.Reconnectant -= OnReconnectant;
        SignalR.Reconnectat -= OnReconnectat;
        SignalR.Desconnectat -= OnDesconnectat;
        if (_grupSeleccionat != null)
            await SignalR.AbandonarGrupAsync(_grupSeleccionat.Id);
    }

    private List<FranjaHorariaModel> FranjesMati()
        => _franjes.Where(f => f.EsMati).OrderBy(f => f.Ordre).ToList();

    private List<FranjaHorariaModel> FranjesTarda()
        => _franjes.Where(f => !f.EsMati).OrderBy(f => f.Ordre).ToList();

    private void ActualitzarBreadcrumbs()
    {
        if (_fase == Fase.SeleccionarGrup)
        {
            BreadcrumbService.Set(
                new("Inici", "/"),
                new("Passar llista", null, true));
        }
        else if (_fase == Fase.SeleccionarFranja)
        {
            BreadcrumbService.Set(
                new("Inici", "/"),
                new("Passar llista", "/passar-llista"),
                new(_grupSeleccionat?.NomComplet ?? string.Empty, null, true));
        }
        else
        {
            BreadcrumbService.Set(
                new("Inici", "/"),
                new("Passar llista", "/passar-llista"),
                new(_grupSeleccionat?.NomComplet ?? string.Empty, null, false),
                new(_etiquetaFranja, null, true));
        }
    }
}

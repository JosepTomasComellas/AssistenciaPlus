@inherits LayoutComponentBase
@inject AuthService AuthService
@inject IdiomesService Idiomes
@inject NavigationManager Nav
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <!-- AppBar -->
            <MudAppBar Elevation="2" Color="Color.Primary" Dense="false">
                <MudTooltip Text="Obrir menú">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                        Color="Color.Inherit"
                        Edge="Edge.Start"
                        OnClick="ToggleDrawer" />
                </MudTooltip>

                <!-- Logo i nom escola -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="ml-1">
                    <MudImage Src="https://agora.xtec.cat/escolamartamata-viladecans/wp-content/uploads/usu1599/2016/11/logomartamata.jpg"
                        Height="40" Alt="Escola Marta Mata"
                        Style="border-radius:4px;object-fit:contain;background:#fff;" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1"
                            Style="font-weight:700;line-height:1.1;color:white">
                            AssistenciaPlus
                        </MudText>
                        <MudText Typo="Typo.caption"
                            Style="line-height:1;opacity:0.85;color:white">
                            Escola Marta Mata · Viladecans
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudSpacer />

                <!-- Toggle idioma -->
                <MudToggleIconButton
                    Toggled="@(!Idiomes.EsCatala)"
                    ToggledChanged="CanviarIdiomaAsync"
                    Icon="@("CA")" ToggledIcon="@("ES")"
                    Color="Color.Inherit" ToggledColor="Color.Inherit"
                    Style="font-size:0.7rem;font-weight:700;min-width:36px"
                    title="@(Idiomes.EsCatala ? "Canviar a castellà" : "Cambiar a català")" />

                <!-- Usuari actual -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.body2"
                        Style="color:white;opacity:0.9"
                        Class="d-none d-sm-flex">
                        @context.User.Identity?.Name
                    </MudText>
                    <MudMenu AnchorOrigin="Origin.BottomRight"
                        TransformOrigin="Origin.TopRight">
                        <ActivatorContent Context="_">
                            <MudButton Variant="Variant.Text" Color="Color.Inherit"
                                Style="min-width:0;padding:2px;border-radius:50%;overflow:hidden">
                                @if (!string.IsNullOrEmpty(_usuariActual?.FotoPath))
                                {
                                    <img src="@_usuariActual.FotoPath" alt=""
                                        style="width:34px;height:34px;border-radius:50%;object-fit:cover;display:block;border:2px solid rgba(255,255,255,0.5)" />
                                }
                                else
                                {
                                    <MudAvatar Color="Color.Secondary" Size="Size.Small"
                                        Style="font-size:0.75rem;font-weight:700;border:2px solid rgba(255,255,255,0.5)">
                                        @(_usuariActual?.NomComplet is { Length: > 0 } nom
                                            ? nom[..Math.Min(2, nom.Length)]
                                            : "?")
                                    </MudAvatar>
                                }
                            </MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Person"
                                OnClick="@(() => Nav.NavigateTo("/perfil"))">
                                El meu perfil
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Logout"
                                OnClick="LogoutAsync">
                                Tancar sessió
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </MudStack>
            </MudAppBar>

            <!-- Drawer lateral -->
            <MudDrawer @bind-Open="_drawerOpen"
                Elevation="1"
                Variant="DrawerVariant.Responsive"
                ClipMode="DrawerClipMode.Always"
                Color="Color.Surface">
                <MudDrawerHeader Class="pa-4">
                    <MudText Typo="Typo.overline"
                        Style="color:var(--mud-palette-text-secondary)">
                        NAVEGACIÓ
                    </MudText>
                </MudDrawerHeader>
                <NavMenu />
            </MudDrawer>

            <!-- Contingut principal -->
            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 pa-sm-6">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>

    <NotAuthorized>
            @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;
    private UsuariModel? _usuariActual;

    protected override async Task OnInitializedAsync()
    {
        Idiomes.IdiomaCanviat += OnIdiomaCanviat;
        _usuariActual = await AuthService.GetCurrentUserFromApiAsync();
    }

    public void Dispose()
        => Idiomes.IdiomaCanviat -= OnIdiomaCanviat;

    private void OnIdiomaCanviat() => InvokeAsync(StateHasChanged);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task CanviarIdiomaAsync(bool esEspanyol)
        => await Idiomes.CanviarIdiomaAsync(esEspanyol ? "es" : "ca");

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}

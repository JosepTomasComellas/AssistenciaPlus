@inherits LayoutComponentBase
@inject AuthService AuthService
@inject IdiomesService Idiomes
@inject BreadcrumbService Breadcrumbs
@inject NavigationManager Nav
@inject SignalRService SignalR
@inject NotificacioService Notificacions
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <!-- AppBar -->
            <MudAppBar Elevation="2" Color="Color.Primary" Dense="false">
                <MudTooltip Text="Obrir menú">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                        Color="Color.Inherit"
                        Edge="Edge.Start"
                        OnClick="ToggleDrawer" />
                </MudTooltip>

                <!-- Logo i nom escola -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="ml-1"
                    Style="cursor:pointer" @onclick="@(() => Nav.NavigateTo("/"))">
                    <MudImage Src="https://agora.xtec.cat/escolamartamata-viladecans/wp-content/uploads/usu1599/2016/11/logomartamata.jpg"
                        Height="40" Alt="Escola Marta Mata"
                        Style="border-radius:4px;object-fit:contain;background:#fff;" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1"
                            Style="font-weight:700;line-height:1.1;color:white">
                            AssistenciaPlus
                        </MudText>
                        <MudText Typo="Typo.caption"
                            Style="line-height:1;opacity:0.85;color:white">
                            Escola Marta Mata · Viladecans
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudSpacer />

                <!-- Toggle idioma -->
                <MudToggleIconButton
                    Toggled="@(!Idiomes.EsCatala)"
                    ToggledChanged="CanviarIdiomaAsync"
                    Icon="@("CA")" ToggledIcon="@("ES")"
                    Color="Color.Inherit" ToggledColor="Color.Inherit"
                    Style="font-size:0.7rem;font-weight:700;min-width:36px"
                    title="@(Idiomes.EsCatala ? "Canviar a castellà" : "Cambiar a català")" />

                <!-- Campana de notificacions -->
                <MudMenu @ref="_menuNotif" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                    Dense="true" Style="max-width:340px">
                    <ActivatorContent Context="notifCtx">
                        <MudBadge Content="@Notificacions.NoLlegides" Overlap="true"
                            Color="Color.Error" Visible="@(Notificacions.NoLlegides > 0)">
                            <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                                Color="Color.Inherit" title="Notificacions d'absència"
                                OnClick="@(e => _menuNotif.OpenMenuAsync(e))" />
                        </MudBadge>
                    </ActivatorContent>
                    <ChildContent>
                        <div style="min-width:280px;max-width:340px">
                            <div class="d-flex align-center justify-space-between pa-3 pb-1">
                                <MudText Typo="Typo.subtitle2" Style="font-weight:700">
                                    Alertes d'absència
                                </MudText>
                                @if (Notificacions.NoLlegides > 0)
                                {
                                    <MudButton Size="Size.Small" Variant="Variant.Text"
                                        OnClick="@(() => Notificacions.EsborrarTotes())">
                                        Netejar
                                    </MudButton>
                                }
                            </div>
                            <MudDivider />
                            @if (!Notificacions.Alertes.Any())
                            {
                                <div class="pa-4 text-center">
                                    <MudText Typo="Typo.body2" Style="color:#A0AEC0">
                                        Cap alerta activa
                                    </MudText>
                                </div>
                            }
                            else
                            {
                                @foreach (var alerta in Notificacions.Alertes.Take(8))
                                {
                                    <div class="pa-2" style="border-bottom:1px solid #F0F0F0">
                                        <div class="d-flex align-start gap-2">
                                            <MudIcon Icon="@(alerta.EsCritic ? Icons.Material.Filled.Warning : Icons.Material.Filled.Info)"
                                                Size="Size.Small"
                                                Style="@($"color:{(alerta.EsCritic ? "#C62828" : "#F57F17")};margin-top:2px;flex-shrink:0")" />
                                            <div>
                                                <MudText Typo="Typo.body2" Style="font-weight:600;line-height:1.2">
                                                    @alerta.AlumneNom
                                                </MudText>
                                                <MudText Typo="Typo.caption" Style="color:#718096">
                                                    @alerta.GrupNom · @alerta.Missatge
                                                </MudText>
                                                <MudText Typo="Typo.caption" Style="color:#A0AEC0">
                                                    @alerta.Moment.ToString("HH:mm")
                                                </MudText>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </ChildContent>
                </MudMenu>

                <!-- Usuari actual -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.body2"
                        Style="color:white;opacity:0.9"
                        Class="d-none d-sm-flex">
                        @context.User.Identity?.Name
                    </MudText>
                    <!-- Wrapper de 40x40: el MudMenu és clickable; l'avatar és una capa visual per sobre -->
                    <div style="position:relative;width:40px;height:40px;flex-shrink:0">
                        <MudMenu Icon="@Icons.Material.Filled.AccountCircle"
                            Color="Color.Inherit"
                            AnchorOrigin="Origin.BottomRight"
                            TransformOrigin="Origin.TopRight">
                            <MudMenuItem Icon="@Icons.Material.Filled.Person"
                                OnClick="@(() => Nav.NavigateTo("/perfil"))">
                                El meu perfil
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Logout"
                                OnClick="LogoutAsync">
                                Tancar sessió
                            </MudMenuItem>
                        </MudMenu>
                        @if (!string.IsNullOrEmpty(_usuariActual?.FotoPath))
                        {
                            <img src="@_usuariActual.FotoPath" alt=""
                                style="position:absolute;top:4px;left:4px;width:32px;height:32px;border-radius:50%;object-fit:cover;pointer-events:none;border:2px solid rgba(255,255,255,0.6)" />
                        }
                        else if ((_usuariActual?.NomComplet ?? context.User.Identity?.Name) is { Length: > 0 } nomU)
                        {
                            <div style="position:absolute;top:4px;left:4px;width:32px;height:32px;border-radius:50%;background:#7B1FA2;display:flex;align-items:center;justify-content:center;color:white;font-size:0.7rem;font-weight:700;pointer-events:none;letter-spacing:0.02em">
                                @nomU[..Math.Min(2, nomU.Length)]
                            </div>
                        }
                    </div>
                </MudStack>
            </MudAppBar>

            <!-- Drawer lateral -->
            <MudDrawer @bind-Open="_drawerOpen"
                Elevation="1"
                Variant="DrawerVariant.Responsive"
                ClipMode="DrawerClipMode.Always"
                Color="Color.Surface">
                <MudDrawerHeader Class="pa-4">
                    <MudText Typo="Typo.overline"
                        Style="color:var(--mud-palette-text-secondary)">
                        NAVEGACIÓ
                    </MudText>
                </MudDrawerHeader>
                <NavMenu />
            </MudDrawer>

            <!-- Contingut principal -->
            <MudMainContent Style="display:flex;flex-direction:column;min-height:100dvh">
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 pa-sm-6"
                    Style="flex:1">
                    @if (Breadcrumbs.Items.Count > 1)
                    {
                        <MudBreadcrumbs Items="Breadcrumbs.Items.ToList()"
                            Class="px-0 pt-0 pb-3" Style="font-size:0.85rem" />
                    }
                    @Body
                </MudContainer>

                <!-- Peu de pàgina (sempre visible a la part inferior) -->
                <div class="d-flex align-center justify-center flex-wrap gap-2 pa-2"
                    Style="border-top:1px solid #E2E8F0;background:#FAFBFD;flex-shrink:0">
                    <MudText Typo="Typo.caption" Style="color:#718096">
                        <strong>AssistenciaPlus</strong> v0.5.0
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#CBD5E0">·</MudText>
                    <MudText Typo="Typo.caption" Style="color:#718096">
                        Escola Marta Mata · Viladecans · © @DateTime.Now.Year
                    </MudText>
                </div>
            </MudMainContent>
        </MudLayout>
    </Authorized>

    <NotAuthorized>
            @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;
    private UsuariModel? _usuariActual;
    private MudMenu _menuNotif = null!;

    protected override async Task OnInitializedAsync()
    {
        Idiomes.IdiomaCanviat += OnIdiomaCanviat;
        Breadcrumbs.OnChange += OnBreadcrumbsCanviat;
        Notificacions.OnChange += OnNotificacioCanviada;
        _usuariActual = await AuthService.GetCurrentUserFromApiAsync();

        // Connecta SignalR per rebre alertes d'absència (no bloqueja la càrrega)
        _ = ConnectarSignalRAsync();
    }

    private async Task ConnectarSignalRAsync()
    {
        try
        {
            await SignalR.ConnectarAsync();
            SignalR.AlertaAbsencia += OnAlertaAbsencia;
        }
        catch { /* SignalR no és crític */ }
    }

    private void OnAlertaAbsencia(
        string alumneId, string alumneNom, string grupNom, string missatge, bool esCritic)
    {
        var alerta = new NotificacioModel(
            Guid.TryParse(alumneId, out var id) ? id : Guid.Empty,
            alumneNom, grupNom, missatge, DateTime.Now, esCritic);
        Notificacions.AfegirAlerta(alerta);
    }

    private void OnNotificacioCanviada() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Idiomes.IdiomaCanviat -= OnIdiomaCanviat;
        Breadcrumbs.OnChange -= OnBreadcrumbsCanviat;
        Notificacions.OnChange -= OnNotificacioCanviada;
        SignalR.AlertaAbsencia -= OnAlertaAbsencia;
    }

    private void OnBreadcrumbsCanviat() => InvokeAsync(StateHasChanged);

    private void OnIdiomaCanviat() => InvokeAsync(StateHasChanged);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task CanviarIdiomaAsync(bool esEspanyol)
        => await Idiomes.CanviarIdiomaAsync(esEspanyol ? "es" : "ca");

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
